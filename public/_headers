# Security headers for Netlify / Cloudflare Pages (static-host format).
# If you deploy on Vercel, replicate these in vercel.json instead (see
# REMAINING-SEO-TASKS.md). No Content-Security-Policy is set here on purpose —
# add one only after testing, since the site uses inline scripts/styles.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000

# Long-cache fingerprinted build assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
