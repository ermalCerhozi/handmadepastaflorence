---
// B2B band — partnerships with hotels, tour operators and companies.
// Enquiries go to email (not the WhatsApp booking flow) since these are
// bespoke, multi-party conversations rather than instant class bookings.
const offers = [
  {
    t: 'Hotels, B&Bs & agriturismi',
    d: 'Give your guests a pasta class to remember. Partner rates, easy referral booking, and classes in English or Italian — five minutes from the Ponte Vecchio.',
    points: ['Partner & referral rates', 'Priority booking for your guests', 'Co-branded gift vouchers'],
  },
  {
    t: 'Corporate team building',
    d: 'Aprons on, laptops away. A private hands-on class where your team rolls, folds, laughs and then sits down to a long lunch it made itself.',
    points: ['Private kitchen buyout, 6–14 people', 'English-speaking chefs', 'Wine pairing & dietary options'],
  },
  {
    t: 'Tour operators & travel planners',
    d: 'A reliable, small-group food experience for your Florence itineraries — fixed time slots, fast confirmation, and two head chefs who host every class themselves.',
    points: ['Fixed schedule, fast confirmation', 'Group & series pricing', 'Market-walk add-on available'],
  },
];
---

<section class="b2b" id="business">
  <div class="shell">
    <header class="b2b__head" data-reveal>
      <div>
        <p class="eyebrow b2b__eyebrow">For businesses</p>
        <h2 class="b2b__title">Work <span class="ital">with us.</span></h2>
      </div>
      <p class="b2b__intro">
        We partner with hotels, tour operators and companies to bring the
        farmhouse table to their guests and teams — in our Oltrarno kitchen or live online.
      </p>
    </header>

    <div class="b2b__grid">
      {offers.map((o, i) => (
        <article class="b2b__card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <h3 class="b2b__t">{o.t}</h3>
          <p class="b2b__d">{o.d}</p>
          <ul class="b2b__points">
            {o.points.map((p) => (
              <li>{p}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="b2b__cta" data-reveal>
      <p>Tell us about your guests, group or team — we reply within one working day.</p>
      <a class="b2b__btn" href="mailto:ciao@handmadepastaflorence.com?subject=Business%20partnership%20enquiry">
        Start a partnership <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .b2b { padding-block: clamp(4rem, 10vh, 7rem); background: var(--olive); color: var(--flour); }
  .b2b__head {
    display: grid; gap: 1.2rem 3rem; align-items: end;
    grid-template-columns: 1fr; margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 820px) { .b2b__head { grid-template-columns: 1.2fr 1fr; } }
  .b2b__eyebrow { color: var(--yolk); margin-bottom: 0.9rem; }
  .b2b__title { font-size: var(--step-3); }
  .b2b__title .ital { color: var(--yolk); }
  .b2b__intro { color: rgba(249,246,240,0.8); font-size: var(--step-0); line-height: 1.6; max-width: 44ch; }

  .b2b__grid {
    display: grid; gap: clamp(1rem, 2vw, 1.6rem);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
  }
  .b2b__card {
    padding: 1.6rem; border-radius: var(--radius-lg);
    background: rgba(249,246,240,0.06); border: 1px solid rgba(249,246,240,0.14);
    cursor: pointer;
    transition: background 0.4s var(--ease);
  }
  .b2b__card:hover { background: rgba(249,246,240,0.1); }
  .b2b__t { font-size: var(--step-1); color: var(--yolk); margin-bottom: 0.6rem; }
  .b2b__d { font-size: var(--step--1); line-height: 1.6; color: rgba(249,246,240,0.82); }
  .b2b__points { margin-top: 1rem; display: grid; gap: 0.4rem; }
  .b2b__points li {
    font-size: var(--step--1); color: rgba(249,246,240,0.7); padding-left: 1.1rem; position: relative;
  }
  .b2b__points li::before { content: '·'; position: absolute; left: 0.2rem; color: var(--yolk); font-weight: 800; }

  .b2b__cta {
    margin-top: clamp(2rem, 4vw, 3rem); display: flex; flex-wrap: wrap; align-items: center;
    justify-content: space-between; gap: 1.2rem; padding-top: 1.6rem;
    border-top: 1px solid rgba(249,246,240,0.16);
  }
  .b2b__cta p { color: rgba(249,246,240,0.75); font-size: var(--step--1); max-width: 46ch; }
  .b2b__btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--yolk); color: var(--olive-deep); font-weight: 800;
    padding: 0.9rem 1.5rem; border-radius: 100px;
    transition: gap 0.3s;
  }
  .b2b__btn:hover { gap: 0.9rem; }
</style>
