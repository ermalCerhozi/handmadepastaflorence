---
// Frictionless 3-step booking request drawer (off-canvas, right side on desktop / full-screen on mobile).
// State + pricing handled client-side.
//   1. Experience + guests   2. Date & time   3. Customize (add-ons)
// The final step sends the request by opening a prefilled WhatsApp chat.
// Pricing is always tied to a visible guest count, so the total can never appear
// "out of nowhere" — it updates the moment an experience and guest count are chosen.
---

<div class="bk" data-booking hidden>
  <div class="bk__scrim" data-close-booking></div>

  <aside class="bk__panel" role="dialog" aria-modal="true" aria-label="Book a pasta class">
    <!-- Header: numbered stepper + close -->
    <header class="bk__top">
      <ol class="bk__steps" data-steps>
        <li class="bk__step is-active" data-step-dot="1">
          <span class="bk__dot"><i class="bk__num">1</i></span>
          <span class="bk__label">Experience</span>
        </li>
        <li class="bk__step" data-step-dot="2">
          <span class="bk__dot"><i class="bk__num">2</i></span>
          <span class="bk__label">Date &amp; time</span>
        </li>
        <li class="bk__step" data-step-dot="3">
          <span class="bk__dot"><i class="bk__num">3</i></span>
          <span class="bk__label">Customize</span>
        </li>
      </ol>
      <button class="bk__close" data-close-booking aria-label="Close booking">✕</button>
    </header>

    <div class="bk__scroll">
      <!-- ===== Step 1: experience + guests ===== -->
      <section class="bk__view is-active" data-view="1">
        <p class="bk__kicker">Step 1</p>
        <h2 class="bk__h">Choose your experience</h2>
        <div class="bk__choices">
          <button class="choice" data-choice="florence" data-price="95">
            <span class="choice__emoji">🍝</span>
            <span class="choice__t">In-Person · Florence</span>
            <span class="choice__d">Three hands-on hours in our Oltrarno kitchen, ending in a long lunch.</span>
            <span class="choice__p">€95<small>/person</small></span>
            <span class="choice__check" aria-hidden="true">✓</span>
          </button>
          <button class="choice" data-choice="online" data-price="68">
            <span class="choice__emoji">💻</span>
            <span class="choice__t">Live Online</span>
            <span class="choice__d">Cook live from anywhere with a kit shipped to your door.</span>
            <span class="choice__p">€68<small>/person</small></span>
            <span class="choice__check" aria-hidden="true">✓</span>
          </button>
        </div>

        <!-- Guests live here so the price is never a surprise -->
        <div class="qty" data-qty-block hidden>
          <div class="qty__info">
            <span class="qty__label">How many guests?</span>
            <span class="qty__hint" data-qty-hint>—</span>
          </div>
          <div class="qty__ctrl">
            <button data-qty="-1" aria-label="Fewer guests">−</button>
            <strong data-qty-val>1</strong>
            <button data-qty="1" aria-label="More guests">+</button>
          </div>
        </div>
      </section>

      <!-- ===== Step 2: date & time ===== -->
      <section class="bk__view" data-view="2">
        <p class="bk__kicker">Step 2</p>
        <h2 class="bk__h">Pick a date &amp; time</h2>

        <div class="cal">
          <div class="cal__bar">
            <button class="cal__nav" data-cal-prev aria-label="Previous month">←</button>
            <strong data-cal-label>—</strong>
            <button class="cal__nav" data-cal-next aria-label="Next month">→</button>
          </div>
          <div class="cal__dow"><span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span></div>
          <div class="cal__grid" data-cal-grid></div>
        </div>

        <div class="slots" data-slots hidden>
          <p class="slots__label">Available times <span data-slot-date></span></p>
          <div class="slots__row" data-slot-row></div>
          <div class="tz" data-tz hidden>
            <span class="tz__row"><i>🇮🇹 Florence</i><b data-tz-florence>—</b></span>
            <span class="tz__arrow">→</span>
            <span class="tz__row"><i data-tz-name>Your time</i><b data-tz-local>—</b></span>
          </div>
        </div>
      </section>

      <!-- ===== Step 3: add-ons ===== -->
      <section class="bk__view" data-view="3">
        <p class="bk__kicker">Step 3</p>
        <h2 class="bk__h">Make it yours</h2>
        <p class="bk__sub">Optional. Everything here is add-on only.</p>
        <div class="adds">
          <label class="add" data-addon="kit" data-add-price="34" data-per="order" data-online-only>
            <span class="add__main">
              <span class="add__t">Ship me the ingredient kit</span>
              <span class="add__d">00 flour, semola, rolling pin &amp; recipe cards, chilled to your door.</span>
            </span>
            <span class="add__price">+€34</span>
            <span class="switch"><input type="checkbox" /><span class="switch__track"></span></span>
          </label>
          <label class="add" data-addon="wine" data-add-price="18" data-per="guest">
            <span class="add__main">
              <span class="add__t">Add a wine pairing</span>
              <span class="add__d">Two Tuscan pours chosen to match your menu (in-person) or a bottle shipped (online).</span>
            </span>
            <span class="add__price">+€18<small>/person</small></span>
            <span class="switch"><input type="checkbox" /><span class="switch__track"></span></span>
          </label>
          <label class="add" data-addon="gf" data-add-price="0" data-per="order">
            <span class="add__main">
              <span class="add__t">Gluten-free preference</span>
              <span class="add__d">We’ll prep a dedicated GF flour blend and a clean station. No charge.</span>
            </span>
            <span class="add__price">Free</span>
            <span class="switch"><input type="checkbox" /><span class="switch__track"></span></span>
          </label>
        </div>
      </section>
    </div>

    <!-- ===== Sticky order summary + nav ===== -->
    <footer class="bk__bottom">
      <div class="summary">
        <p class="summary__title">Order summary</p>
        <ul class="summary__lines" data-summary-lines></ul>
        <div class="summary__total">
          <span>Total</span>
          <strong data-total>€0</strong>
        </div>
      </div>
      <div class="bk__actions">
        <button class="bk__back" data-prev hidden>Back</button>
        <button class="bk__next" data-next disabled>Continue</button>
      </div>
    </footer>
  </aside>
</div>

<script>
  type Experience = 'florence' | 'online';
  type State = {
    step: number;
    experience: Experience | null;
    basePrice: number;
    date: string | null;
    time: string | null;
    guests: number;
    addons: Record<string, number>;
  };

  const PRICES: Record<Experience, number> = { florence: 95, online: 68 };
  const MIN_GUESTS = 1;
  const MAX_GUESTS = 14;

  // WhatsApp business number (digits only, international format — same as endricerhozi.com).
  const WHATSAPP_NUMBER = '393445204379';
  // Official WhatsApp glyph, inlined so the button needs no extra asset request.
  // Width/height are set on the element itself: this SVG is injected via innerHTML,
  // so it never receives Astro's scoped-style attribute and the `.bk__wa-icon` CSS
  // rule below would not apply to it.
  const WHATSAPP_ICON =
    '<svg class="bk__wa-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">'
    + '<path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.582 0 11.943-5.359 11.945-11.893a11.821 11.821 0 00-3.418-8.452z"/>'
    + '</svg>';

  const setupBooking = () => {
    const root = document.querySelector<HTMLElement>('[data-booking]');
    if (!root) return;

    const state: State = {
      step: 1, experience: null, basePrice: 0,
      date: null, time: null, guests: MIN_GUESTS, addons: {},
    };

    const $ = <T extends Element = HTMLElement>(s: string, r: ParentNode = root) => r.querySelector<T>(s);
    const $$ = <T extends Element = HTMLElement>(s: string, r: ParentNode = root) => Array.from(r.querySelectorAll<T>(s));

    /* ---------- open / close ---------- */
    const open = (prefill?: string | null) => {
      root.hidden = false;
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => root.classList.add('is-open'));
      if (prefill === 'florence' || prefill === 'online') $(`[data-choice="${prefill}"]`)?.click();
    };
    const close = () => {
      root.classList.remove('is-open');
      document.body.style.overflow = '';
      window.setTimeout(() => { root.hidden = true; }, 480);
    };
    document.querySelectorAll('[data-open-booking]').forEach((b) =>
      b.addEventListener('click', (e) => {
        e.preventDefault(); // some triggers are <a href="#"> — don't jump to the top
        open((b as HTMLElement).dataset.prefill);
      }));
    $$('[data-close-booking]').forEach((b) => b.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !root.hidden) close(); });

    /* ---------- step navigation ---------- */
    const goTo = (n: number) => {
      state.step = Math.min(3, Math.max(1, n));
      $$('[data-view]').forEach((v) => v.classList.toggle('is-active', v.dataset.view === String(state.step)));
      $$('[data-step-dot]').forEach((d) => {
        const dn = Number(d.dataset.stepDot);
        d.classList.toggle('is-active', dn === state.step);
        d.classList.toggle('is-done', dn < state.step);
      });
      const back = $('[data-prev]');
      if (back) back.hidden = state.step === 1;
      const next = $<HTMLButtonElement>('[data-next]');
      if (next) {
        next.classList.toggle('bk__next--wa', state.step === 3);
        next.innerHTML = state.step === 3
          ? `${WHATSAPP_ICON}<span>Send request</span>`
          : 'Continue';
      }
      const scroll = $('.bk__scroll');
      if (scroll) scroll.scrollTop = 0;
      validate();
    };

    /* ---------- validation per step ---------- */
    const validate = () => {
      const next = $<HTMLButtonElement>('[data-next]');
      if (!next) return;
      let ok = true;
      if (state.step === 1) ok = !!state.experience;          // guests always >= 1
      if (state.step === 2) ok = !!state.date && !!state.time;
      next.disabled = !ok;
    };

    $('[data-next]')?.addEventListener('click', () => {
      if (state.step === 3) { sendRequest(); return; }
      goTo(state.step + 1);
    });
    $('[data-prev]')?.addEventListener('click', () => goTo(state.step - 1));

    /* ---------- step 1: experience + guests ---------- */
    const qtyBlock = $('[data-qty-block]');
    const qtyHint = $('[data-qty-hint]');

    $$('[data-choice]').forEach((btn) => {
      btn.addEventListener('click', () => {
        $$('[data-choice]').forEach((b) => b.classList.remove('is-sel'));
        btn.classList.add('is-sel');
        state.experience = btn.dataset.choice as Experience;
        state.basePrice = Number(btn.dataset.price);

        // reveal the guest control + show per-person price
        if (qtyBlock) qtyBlock.hidden = false;
        if (qtyHint) qtyHint.textContent = `€${state.basePrice} per person`;

        // online-only add-ons: hide for in-person AND drop them from state if active
        $$('[data-online-only]').forEach((a) => {
          const el = a as HTMLElement;
          const show = state.experience === 'online';
          el.style.display = show ? '' : 'none';
          if (!show) {
            const key = el.dataset.addon!;
            const input = el.querySelector<HTMLInputElement>('input');
            if (input?.checked) { input.checked = false; el.classList.remove('is-on'); }
            delete state.addons[key];
          }
        });
        validate();
        render();
      });
    });

    const setGuests = (n: number) => {
      state.guests = Math.min(MAX_GUESTS, Math.max(MIN_GUESTS, n));
      const val = $('[data-qty-val]');
      if (val) val.textContent = String(state.guests);
      // disable −/+ at the bounds
      $$<HTMLButtonElement>('[data-qty]').forEach((b) => {
        const dir = Number(b.dataset.qty);
        b.disabled = (dir < 0 && state.guests === MIN_GUESTS) || (dir > 0 && state.guests === MAX_GUESTS);
      });
      render();
    };
    $$('[data-qty]').forEach((b) =>
      b.addEventListener('click', () => setGuests(state.guests + Number((b as HTMLElement).dataset.qty))));

    /* ---------- step 2: calendar ---------- */
    const today = new Date(); today.setHours(0, 0, 0, 0);
    let view = new Date(today.getFullYear(), today.getMonth(), 1);
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

    // Class times are Florence (Europe/Rome) wall-clock times.
    const FL_TIMES = ['10:00', '14:30', '18:00'];
    // Offset in minutes (east of UTC) of an instant in a named time zone — lets us
    // handle CET/CEST automatically instead of hard-coding a fixed offset.
    const zoneOffset = (instant: Date, tz: string) => {
      const dtf = new Intl.DateTimeFormat('en-US', {
        timeZone: tz, hour12: false,
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', second: '2-digit',
      });
      const p: Record<string, string> = {};
      for (const part of dtf.formatToParts(instant)) p[part.type] = part.value;
      const asUTC = Date.UTC(+p.year, +p.month - 1, +p.day, +p.hour, +p.minute, +p.second);
      return Math.round((asUTC - instant.getTime()) / 60000);
    };
    // Absolute instant (ms since epoch) of a Florence wall-clock slot on a given day.
    const slotMs = (date: Date, time: string) => {
      const [h, m] = time.split(':').map(Number);
      const guess = Date.UTC(date.getFullYear(), date.getMonth(), date.getDate(), h, m);
      return guess - zoneOffset(new Date(guess), 'Europe/Rome') * 60000;
    };
    const hasFutureSlot = (date: Date) => FL_TIMES.some((t) => slotMs(date, t) > Date.now());

    const buildCal = () => {
      const grid = $('[data-cal-grid]'); const label = $('[data-cal-label]');
      if (!grid || !label) return;
      label.textContent = `${MONTHS[view.getMonth()]} ${view.getFullYear()}`;
      grid.innerHTML = '';
      const first = new Date(view.getFullYear(), view.getMonth(), 1);
      const offset = (first.getDay() + 6) % 7; // Mon-first
      const days = new Date(view.getFullYear(), view.getMonth() + 1, 0).getDate();
      for (let i = 0; i < offset; i++) grid.appendChild(document.createElement('span'));
      for (let d = 1; d <= days; d++) {
        const cell = document.createElement('button');
        const date = new Date(view.getFullYear(), view.getMonth(), d);
        cell.textContent = String(d);
        cell.className = 'cal__day';
        const past = date < today;
        const closed = date.getDay() === 1; // closed Mondays
        const elapsed = date.getTime() === today.getTime() && !hasFutureSlot(date); // today, all slots gone
        if (past || closed || elapsed) { cell.disabled = true; cell.classList.add('is-off'); }
        else {
          cell.addEventListener('click', () => {
            $$('.cal__day').forEach((c) => c.classList.remove('is-sel'));
            cell.classList.add('is-sel');
            state.date = date.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' });
            state.time = null;
            showSlots(date);
            validate(); render();
          });
        }
        grid.appendChild(cell);
      }
    };
    $('[data-cal-prev]')?.addEventListener('click', () => {
      const m = new Date(view.getFullYear(), view.getMonth() - 1, 1);
      if (m >= new Date(today.getFullYear(), today.getMonth(), 1)) { view = m; buildCal(); }
    });
    $('[data-cal-next]')?.addEventListener('click', () => {
      view = new Date(view.getFullYear(), view.getMonth() + 1, 1); buildCal();
    });

    const showSlots = (date: Date) => {
      const wrap = $('[data-slots]'); if (!wrap) return;
      wrap.hidden = false;
      const dateLabel = $('[data-slot-date]'); if (dateLabel) dateLabel.textContent = `· ${state.date}`;
      const row = $('[data-slot-row]'); if (!row) return;
      row.innerHTML = '';
      FL_TIMES.forEach((t) => {
        const b = document.createElement('button');
        b.className = 'slot'; b.textContent = t;
        if (slotMs(date, t) <= Date.now()) {
          b.disabled = true; b.classList.add('is-off'); // a time that has already passed today
        } else {
          b.addEventListener('click', () => {
            $$('.slot').forEach((s) => s.classList.remove('is-sel'));
            b.classList.add('is-sel');
            state.time = t;
            showTz(date, t);
            validate(); render();
          });
        }
        row.appendChild(b);
      });
      const tz = $('[data-tz]'); if (tz) tz.hidden = true; // reset until a time is chosen
    };

    const showTz = (date: Date, time: string) => {
      const tz = $('[data-tz]'); if (!tz) return;
      tz.hidden = false;
      // Convert the Florence slot to the visitor's local time, correct year-round (CET/CEST).
      const instant = new Date(slotMs(date, time));
      const localName = Intl.DateTimeFormat().resolvedOptions().timeZone || 'Your time';
      const fmt: Intl.DateTimeFormatOptions = { hour: '2-digit', minute: '2-digit' };
      const fl = $('[data-tz-florence]'); if (fl) fl.textContent = time;
      const nm = $('[data-tz-name]'); if (nm) nm.textContent = localName.replace(/_/g, ' ');
      const lo = $('[data-tz-local]'); if (lo) lo.textContent = instant.toLocaleTimeString(undefined, fmt);
    };

    /* ---------- step 3: add-ons ---------- */
    $$('[data-addon]').forEach((label) => {
      const el = label as HTMLElement;
      const input = el.querySelector<HTMLInputElement>('input')!;
      input.addEventListener('change', () => {
        const key = el.dataset.addon!;
        const price = Number(el.dataset.addPrice);
        el.classList.toggle('is-on', input.checked);
        if (input.checked) state.addons[key] = price; else delete state.addons[key];
        render();
      });
    });

    /* ---------- pricing render (single source of truth) ---------- */
    const euro = (n: number) => `€${n.toLocaleString('en-IE')}`;
    const ADDON_LABELS: Record<string, string> = { kit: 'Ingredient kit', wine: 'Wine pairing', gf: 'Gluten-free' };

    /* ---------- send request → open a prefilled WhatsApp chat ---------- */
    const sendRequest = () => {
      const details: string[] = [];
      let total = 0;
      if (state.experience) {
        const sub = state.basePrice * state.guests;
        total += sub;
        const name = state.experience === 'florence' ? 'In-Person, Florence' : 'Live Online';
        details.push(`Class: ${name} (€${state.basePrice} per person)`);
        details.push(`Guests: ${state.guests}`);
      }
      if (state.date) details.push(`Date & time: ${state.date}${state.time ? ' · ' + state.time : ''}`);

      const addonText: string[] = [];
      $$('[data-addon]').forEach((label) => {
        const el = label as HTMLElement;
        const key = el.dataset.addon!;
        if (!(key in state.addons)) return;
        const unit = state.addons[key];
        const amt = el.dataset.per === 'guest' ? unit * state.guests : unit;
        total += amt;
        addonText.push(`${ADDON_LABELS[key] ?? key}${amt === 0 ? ' (free)' : ' (+' + euro(amt) + ')'}`);
      });
      if (addonText.length) details.push(`Add-ons: ${addonText.join(', ')}`);
      details.push(`Estimated total: ${euro(total)}`);

      const message = [
        'Hi, I would like to book a pasta class.',
        '',
        ...details,
        '',
        'Please confirm availability. Thank you!',
      ].join('\n');

      const url = 'https://wa.me/' + WHATSAPP_NUMBER
        + '?text=' + encodeURIComponent(message);
      window.open(url, '_blank', 'noopener');
    };

    const render = () => {
      const lines = $('[data-summary-lines]'); if (!lines) return;
      lines.innerHTML = '';
      const add = (label: string, amount: number) => {
        const li = document.createElement('li');
        li.innerHTML = `<span>${label}</span><span>${amount === 0 ? 'Free' : euro(amount)}</span>`;
        lines.appendChild(li);
      };

      let total = 0;
      if (state.experience) {
        const sub = state.basePrice * state.guests;
        total += sub;
        const name = state.experience === 'florence' ? 'In Florence' : 'Live Online';
        add(`${name} · €${state.basePrice} × ${state.guests} ${state.guests === 1 ? 'guest' : 'guests'}`, sub);
      }
      // add-ons: per-guest items multiply by guests, per-order items are flat
      $$('[data-addon]').forEach((label) => {
        const el = label as HTMLElement;
        const key = el.dataset.addon!;
        if (!(key in state.addons)) return;
        const unit = state.addons[key];
        const amt = el.dataset.per === 'guest' ? unit * state.guests : unit;
        total += amt;
        add(ADDON_LABELS[key] ?? key, amt);
      });
      if (state.date) add(`📅 ${state.date}${state.time ? ' · ' + state.time : ''}`, 0);

      const totalEl = $('[data-total]'); if (totalEl) totalEl.textContent = euro(total);
    };

    buildCal();
    setGuests(MIN_GUESTS);
    goTo(1);
    render();
  };

  setupBooking();
  document.addEventListener('astro:after-swap', setupBooking);
</script>

<style>
  .bk { position: fixed; inset: 0; z-index: 1000; }
  .bk[hidden] { display: none; }
  .bk__scrim {
    position: absolute; inset: 0; background: rgba(33,44,31,0.55); backdrop-filter: blur(4px);
    opacity: 0; transition: opacity 0.45s var(--ease);
  }
  .bk.is-open .bk__scrim { opacity: 1; }
  .bk__panel {
    --bk-pad: 1.25rem;
    position: absolute; inset: 0 0 0 auto; width: min(460px, 100%);
    background: var(--flour); display: flex; flex-direction: column;
    transform: translateX(100%); transition: transform 0.5s var(--ease);
    box-shadow: var(--shadow-lg);
  }
  .bk.is-open .bk__panel { transform: none; }
  @media (max-width: 460px) { .bk__panel { width: 100%; } }

  /* ---------- header: numbered stepper ---------- */
  .bk__top {
    position: relative; padding: 0.85rem var(--bk-pad) 0.7rem;
    border-bottom: 1px solid var(--paper-line); background: var(--flour-deep);
  }
  .bk__steps {
