---
import { getLocaleFromUrl } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
import { landingPath } from '../data/landings';
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
// Non-translatable per-card data (image + landing key), zipped with t.exp.cards.
const cardMeta = [
  { img: '/images/cooking_class_with_guests_in_picture.webp', w: 1050, h: 1400, key: 'pasta-making' },
  { img: '/images/aperitivo.webp', w: 1080, h: 1440, key: 'market-tour' },
  { img: '/images/wedding-cake-2.webp', w: 1080, h: 1433, key: 'private' },
];

---

<section class="exp" id="experiences">
  <div class="shell">
    <header class="exp__head">
      <div data-reveal>
        <p class="eyebrow exp__eyebrow">{t.exp.eyebrow}</p>
        <h2 class="exp__title">{t.exp.titlePre}<br />{t.exp.titleMid}<span class="ital">{t.exp.titleItal}</span></h2>
      </div>
      <p class="exp__intro" data-reveal style="--reveal-delay:120ms">
        {t.exp.intro}
      </p>
    </header>

    <div class="exp__grid">
      {t.exp.cards.map((c, i) => {
        const m = cardMeta[i];
        const href = landingPath(m.key, lang);
        return (
        <article class="card" data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <div class="card__media">
            <img class="card__img" src={m.img} alt={c.alt} width={m.w} height={m.h} loading="lazy" decoding="async" />
            <span class="card__tag">{c.tag}</span>
            <span class="card__price">{c.price}</span>
          </div>
          <div class="card__body">
            <h3 class="card__name"><a href={href}>{c.name}</a></h3>
            <p class="card__desc">{c.desc}</p>
            <p class="card__meta">{c.meta}</p>
            <div class="card__actions">
              <button class="card__cta" data-open-booking data-prefill="florence">
                {t.exp.book} <span aria-hidden="true">→</span>
              </button>
              <a class="card__more" href={href}>{t.exp.more}</a>
            </div>
          </div>
        </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .exp { padding-block: clamp(4.5rem, 12vh, 9rem); position: relative; }
  .exp__head {
    display: grid; gap: 1.4rem 3rem; align-items: end;
    grid-template-columns: 1fr; margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  @media (min-width: 820px) { .exp__head { grid-template-columns: 1.4fr 1fr; } }
  .exp__eyebrow { color: var(--terracotta); margin-bottom: 0.9rem; }
  .exp__title { font-size: var(--step-3); color: var(--olive); }
  .exp__title .ital { color: var(--terracotta); }
  .exp__intro { color: var(--charcoal-soft); font-size: var(--step-0); line-height: 1.6; max-width: 42ch; }

  .exp__grid {
    display: grid; gap: clamp(1.2rem, 2.5vw, 2rem);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 290px), 1fr));
  }

  .card {
    background: #fff; border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid var(--paper-line); box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column; cursor: pointer;
    transition: box-shadow 0.5s var(--ease);
  }
  .card:hover { box-shadow: var(--shadow-lg); }
  .card__media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; background: var(--flour-shadow); }
  .card__img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.7s var(--ease);
  }
  .card:hover .card__img { transform: scale(1.07); }
  /* bottom scrim so the white price stays readable over any photo */
  .card__media::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(to top, rgba(33,44,31,0.55), transparent 42%);
  }
  .card__tag {
    position: absolute; top: 1rem; left: 1rem; z-index: 1;
    background: rgba(249,246,240,0.92); color: var(--olive);
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 0.35rem 0.7rem; border-radius: 100px;
  }
  .card__price {
    position: absolute; bottom: 1rem; right: 1rem; z-index: 1;
    font-family: var(--serif); font-weight: 800; font-size: 1.5rem; color: #fff;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  }
  .card__body { padding: 1.5rem 1.5rem 1.7rem; display: flex; flex-direction: column; flex: 1; }
  .card__name { font-size: var(--step-1); color: var(--olive); margin-bottom: 0.6rem; }
  .card__name a { color: inherit; transition: color 0.3s; }
  .card__name a:hover { color: var(--terracotta); }
  .card__desc { color: var(--charcoal-soft); font-size: var(--step--1); line-height: 1.6; flex: 1; }
  .card__meta {
    margin-top: 1rem; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.02em;
    color: var(--terracotta); text-transform: uppercase;
  }
  .card__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem 1.5rem; margin-top: 1.2rem; }
  .card__cta {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-weight: 700; color: var(--olive);
    border-bottom: 2px solid var(--yolk); padding-bottom: 3px;
    transition: gap 0.35s var(--ease), color 0.3s;
  }
  .card__cta:hover { gap: 0.9rem; color: var(--terracotta); }
  .card__more {
    font-weight: 600; font-size: var(--step--1); color: var(--charcoal-soft);
    text-decoration: underline; text-underline-offset: 3px; transition: color 0.3s;
  }
  .card__more:hover { color: var(--terracotta); }
</style>
