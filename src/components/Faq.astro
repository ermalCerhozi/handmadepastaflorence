---
// FAQ section — answers common booking questions and feeds FAQPage schema.
// Every answer is grounded in facts already published elsewhere on the site.
// Add cancellation / payment / exact-address answers once confirmed by the owner
// (see REMAINING-SEO-TASKS.md).
import { getLocaleFromUrl } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
const t = useTranslations(getLocaleFromUrl(Astro.url));
const faqs = t.faq.items;

---

<section class="faq" id="faq">
  <div class="shell faq__inner">
    <header class="faq__head" data-reveal>
      <p class="eyebrow faq__eyebrow">{t.faq.eyebrow}</p>
      <h2 class="faq__title">{t.faq.titlePre} <span class="ital">{t.faq.titleItal}</span></h2>
    </header>

    <div class="faq__list">
      {faqs.map((f, i) => (
        <details class="faq__item" data-reveal style={`--reveal-delay:${i * 50}ms`}>
          <summary class="faq__q">
            {f.q}
            <span class="faq__icon" aria-hidden="true">+</span>
          </summary>
          <p class="faq__a">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
})} />

<style>
  .faq { padding-block: clamp(3.5rem, 9vh, 6rem); background: var(--flour); }
  .faq__head { margin-bottom: clamp(2rem, 4vw, 3rem); }
  .faq__eyebrow { color: var(--terracotta); margin-bottom: 0.7rem; }
  .faq__title { font-size: var(--step-3); color: var(--olive); }
  .faq__title .ital { color: var(--terracotta); }

  .faq__list { display: grid; gap: 0.8rem; max-width: 760px; }
  .faq__item {
    background: #fff; border: 1px solid var(--paper-line); border-radius: var(--radius);
    padding: 0 1.3rem; box-shadow: var(--shadow-sm);
  }
  .faq__q {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    cursor: pointer; list-style: none; padding: 1.1rem 0;
    font-family: var(--serif); font-weight: 700; font-size: var(--step-0); color: var(--olive);
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__icon {
    color: var(--terracotta); font-size: 1.4rem; line-height: 1; flex-shrink: 0;
    transition: transform 0.3s var(--ease);
  }
  .faq__item[open] .faq__icon { transform: rotate(45deg); }
  .faq__a {
    margin: 0 0 1.2rem; color: var(--charcoal); line-height: 1.6;
    font-size: var(--step--1); max-width: 64ch;
  }
</style>
