---
const year = new Date().getFullYear();
---

<footer class="ft">
  <div class="shell">
    <div class="ft__cta" data-reveal>
      <h2 class="ft__h">Come get your hands<br /><span class="ital">a little floury.</span></h2>
      <button class="ft__btn" data-open-booking>
        Book your class
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <div class="ft__grid">
      <div class="ft__brand">
        <span class="ft__name"><strong>Handmade Pasta</strong> <em>Florence</em></span>
        <p>Via dei Pastai 12, Oltrarno · Firenze, Italy</p>
        <p><a href="tel:+393445204379">+39 344 5204379</a></p>
        <p class="ft__hours">Tue–Sun · classes 10:00, 14:30 &amp; 18:00 · closed Mondays</p>
        <p>Cooking together, in person & online, in the heart of Florence.</p>
      </div>
      <nav class="ft__col">
        <h3>Classes</h3>
        <a href="#experiences">In Florence</a>
        <a href="#online">Live Online</a>
        <a href="#gallery">Pasta Shapes</a>
        <a href="#" data-open-booking>Gift a class</a>
      </nav>
      <nav class="ft__col">
        <h3>Visit</h3>
        <a href="#story">Our Story</a>
        <a href="#experiences">Private Events</a>
        <a href="#faq">FAQ &amp; Allergens</a>
        <a href="mailto:ciao@handmadepastaflorence.com">ciao@…florence.com</a>
        <a class="ft__wa" href="https://wa.me/393445204379" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885M20.52 3.449C18.24 1.245 15.24 0 12.045 0 5.463 0 .104 5.359.101 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.582 0 11.943-5.359 11.945-11.893a11.821 11.821 0 00-3.418-8.452z"/></svg>
          +39 344 5204379
        </a>
      </nav>
    </div>

    <div class="ft__base">
      <span>© {year} Handmade Pasta Florence</span>
      <span class="ft__made">Rolled by hand 🤌 in Firenze</span>
    </div>
  </div>
</footer>

<style>
  .ft { background: var(--olive-deep); color: var(--flour); padding-block: clamp(3.5rem, 9vh, 6rem) 2rem; }
  .ft__cta {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 2rem;
    padding-bottom: clamp(2.5rem, 6vw, 4rem); border-bottom: 1px solid rgba(249,246,240,0.14);
  }
  .ft__h { font-size: var(--step-3); }
  .ft__h .ital { color: var(--yolk); }
  .ft__btn {
    display: inline-flex; align-items: center; gap: 0.6rem; background: var(--yolk); color: var(--olive-deep);
    font-weight: 800; font-size: var(--step-0); padding: 1rem 1.7rem; border-radius: 100px;
    transition: transform 0.4s var(--ease), gap 0.3s;
  }
  .ft__btn:hover { transform: translateY(-3px); gap: 1rem; }

  .ft__grid {
    display: grid; gap: 2rem; padding-block: clamp(2.5rem, 6vw, 4rem);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 180px), 1fr));
  }
  .ft__name { font-family: var(--serif); font-size: 1.5rem; }
  .ft__name strong { font-weight: 800; } .ft__name em { font-style: italic; opacity: 0.85; }
  .ft__brand p { color: rgba(249,246,240,0.6); font-size: var(--step--1); margin-top: 0.6rem; max-width: 30ch; }
  .ft__brand a { color: rgba(249,246,240,0.85); text-decoration: underline; text-underline-offset: 2px; transition: color 0.3s; }
  .ft__brand a:hover { color: var(--flour); }
  .ft__hours { color: rgba(249,246,240,0.6); }
  .ft__col h3 { font-family: var(--sans); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--yolk); margin-bottom: 1rem; }
  .ft__col a { display: block; color: rgba(249,246,240,0.78); font-size: var(--step--1); padding-block: 0.35rem; transition: color 0.3s, padding-left 0.3s; }
  .ft__col a:hover { color: var(--flour); padding-left: 6px; }
  .ft__wa { display: inline-flex; align-items: center; gap: 0.45rem; }
  .ft__wa svg { color: #25D366; flex-shrink: 0; }

  .ft__base {
    display: flex; flex-wrap: wrap; justify-content: space-between; gap: 1rem;
    padding-top: 2rem; border-top: 1px solid rgba(249,246,240,0.14);
    font-size: 0.78rem; color: rgba(249,246,240,0.5);
  }
  .ft__made { color: var(--yolk); }
</style>
