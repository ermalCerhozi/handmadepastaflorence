---
// Online is a small secondary offering — a single slim band, not a headline act.
---

<section class="ob" id="online">
  <div class="shell ob__inner" data-reveal>
    <div class="ob__visual">
      <span class="ob__live"><i></i> Live</span>
      <img class="ob__img" src="/images/cooking-class.jpg" alt="Our Florentine kitchen, where we stream live online classes" width="981" height="1603" loading="lazy" decoding="async" />
    </div>
    <div class="ob__text">
      <p class="eyebrow ob__eyebrow">Can’t make it to Florence?</p>
      <h2 class="ob__title">Cook with us <span class="ital">live online.</span></h2>
      <p class="ob__desc">
        Same nonna, streamed from our kitchen — with an ingredient kit shipped
        to your door. A lovely option (or gift) if Italy isn’t on the calendar yet.
      </p>
      <div class="ob__row">
        <button class="ob__cta" data-open-booking data-prefill="online">
          Join an online class <span aria-hidden="true">→</span>
        </button>
        <span class="ob__price">from <strong>€68</strong> · kit included</span>
      </div>
    </div>
  </div>
</section>

<style>
  .ob { padding-block: clamp(2.5rem, 6vh, 4rem); }
  .ob__inner {
    display: grid; gap: clamp(1.4rem, 4vw, 3rem); align-items: center;
    grid-template-columns: 1fr;
    background: var(--olive); color: var(--flour);
    border-radius: var(--radius-lg); padding: clamp(1.6rem, 4vw, 2.6rem);
    box-shadow: var(--shadow-md); position: relative; overflow: hidden;
  }
  .ob__inner::before {
    content: ''; position: absolute; inset: 0; opacity: 0.5; pointer-events: none;
    background: radial-gradient(60% 80% at 12% 20%, rgba(255,199,44,0.16), transparent 70%);
  }
  @media (min-width: 720px) { .ob__inner { grid-template-columns: 200px 1fr; } }

  .ob__visual {
    position: relative; aspect-ratio: 4/3; border-radius: var(--radius); overflow: hidden;
    background: linear-gradient(135deg, #cc5500, #7a3300);
  }
  @media (min-width: 720px) { .ob__visual { aspect-ratio: 1; } }
  .ob__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ob__live {
    position: absolute; top: 0.7rem; left: 0.7rem; display: inline-flex; align-items: center; gap: 5px;
    background: rgba(0,0,0,0.4); color: #fff; font-size: 0.66rem; font-weight: 800; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 3px 8px; border-radius: 100px;
  }
  .ob__live i { width: 6px; height: 6px; border-radius: 50%; background: #ff4d4d; animation: obpulse 1.4s infinite; }
  @keyframes obpulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

  .ob__eyebrow { color: var(--yolk); margin-bottom: 0.7rem; }
  .ob__title { font-size: var(--step-2); }
  .ob__title .ital { color: var(--yolk); }
  .ob__desc { margin-top: 0.8rem; color: rgba(249,246,240,0.82); font-size: var(--step--1); line-height: 1.6; max-width: 52ch; }
  .ob__row { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem 1.4rem; margin-top: 1.4rem; }
  .ob__cta {
    display: inline-flex; align-items: center; gap: 0.5rem; background: var(--yolk); color: var(--olive-deep);
    font-weight: 800; padding: 0.8rem 1.4rem; border-radius: 100px; transition: transform 0.35s var(--ease), gap 0.3s;
  }
  .ob__cta:hover { transform: translateY(-2px); gap: 0.9rem; }
  .ob__price { font-size: var(--step--1); color: rgba(249,246,240,0.75); }
  .ob__price strong { font-family: var(--serif); font-size: var(--step-0); color: var(--flour); }
</style>
