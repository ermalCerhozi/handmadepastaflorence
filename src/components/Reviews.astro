---
// Customer reviews — intentionally EMPTY until we start receiving real ones.
// To populate later: add objects to `reviews` (and optionally `badges`) below.
// The whole section reveals automatically once `reviews` has at least one entry.
import { getLocaleFromUrl } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
const t = useTranslations(getLocaleFromUrl(Astro.url));
const reviews: { quote: string; name: string; from: string; src: string }[] = [];
const badges: { src: string; score: string; count: string; mark: string }[] = [];
const hasReviews = reviews.length > 0;
---

{hasReviews && (
<section class="rev" id="reviews">
  <div class="shell">
    <header class="rev__head" data-reveal>
      <div>
        <p class="eyebrow rev__eyebrow">{t.reviews.eyebrow}</p>
        <h2 class="rev__title">{t.reviews.titlePre}<br />{t.reviews.titleMid}<span class="ital">{t.reviews.titleItal}</span></h2>
      </div>
      <div class="rev__badges">
        {badges.map((b) => (
          <div class="badge">
            <span class="badge__mark" aria-hidden="true">{b.mark}</span>
            <span class="badge__score">{b.score}<span class="badge__stars" aria-hidden="true">★★★★★</span></span>
            <span class="badge__src">{b.src}</span>
            <span class="badge__count">{b.count}</span>
          </div>
        ))}
      </div>
    </header>

    <div class="rev__grid">
      {reviews.map((r, i) => (
        <figure class="quote" data-reveal style={`--reveal-delay:${i * 80}ms`}>
          <span class="quote__stars" aria-label="5 out of 5 stars">★★★★★</span>
          <blockquote class="quote__text">“{r.quote}”</blockquote>
          <figcaption class="quote__cap">
            <span class="quote__name">{r.name}</span>
            <span class="quote__meta">{r.from} · via {r.src}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .rev { padding-block: clamp(4rem, 10vh, 7rem); background: var(--flour); }
  .rev__head {
    display: grid; gap: 2rem; align-items: end; margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
    grid-template-columns: 1fr;
  }
  @media (min-width: 880px) { .rev__head { grid-template-columns: 1fr auto; } }
  .rev__eyebrow { color: var(--terracotta); margin-bottom: 0.9rem; }
  .rev__title { font-size: var(--step-3); color: var(--olive); }
  .rev__title .ital { color: var(--terracotta); }

  .rev__badges { display: flex; flex-wrap: wrap; gap: 0.8rem; }
  .badge {
    display: grid; gap: 0.1rem; padding: 0.9rem 1.1rem; background: #fff; border-radius: var(--radius);
    border: 1px solid var(--paper-line); box-shadow: var(--shadow-sm); min-width: 130px;
  }
  .badge__mark {
    width: 28px; height: 28px; border-radius: 50%; display: grid; place-items: center;
    background: var(--olive); color: var(--flour); font-weight: 800; font-size: 0.9rem; margin-bottom: 0.3rem;
  }
  .badge__score { font-family: var(--serif); font-weight: 800; font-size: 1.5rem; color: var(--olive); display: flex; align-items: baseline; gap: 0.4rem; }
  .badge__stars { font-size: 0.7rem; color: var(--yolk-deep); letter-spacing: -1px; }
  .badge__src { font-weight: 700; font-size: 0.8rem; color: var(--charcoal); }
  .badge__count { font-size: 0.74rem; color: var(--charcoal-soft); }

  .rev__grid {
    display: grid; gap: clamp(1rem, 2vw, 1.6rem);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
  }
  .quote {
    margin: 0; padding: 1.6rem; background: #fff; border-radius: var(--radius-lg);
    border: 1px solid var(--paper-line); box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column; gap: 0.9rem; cursor: pointer;
    transition: box-shadow 0.4s var(--ease);
  }
  .quote:hover { box-shadow: var(--shadow-md); }
  .quote__stars { color: var(--yolk-deep); letter-spacing: 1px; }
  .quote__text { font-family: var(--serif); font-size: var(--step-0); line-height: 1.5; color: var(--charcoal); flex: 1; }
  .quote__cap { display: flex; flex-direction: column; padding-top: 0.8rem; border-top: 1px solid var(--paper-line); }
  .quote__name { font-weight: 700; color: var(--olive); }
  .quote__meta { font-size: 0.78rem; color: var(--charcoal-soft); }
</style>
