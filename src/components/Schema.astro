---
// Sitewide structured data (JSON-LD).
//
// The address/phone below mirror the NAP shown on the page. Before relying on
// these for local SEO, confirm they are the real, registered business details
// and add `geo` coordinates + `sameAs` social/GBP links — see
// REMAINING-SEO-TASKS.md (items needing owner input).
const SITE = 'https://handmadepastaflorence.com';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE}/#business`,
  name: 'Handmade Pasta Florence',
  description:
    'Hands-on fresh-pasta cooking classes in Florence taught by two agriturismo head chefs — in person in the Oltrarno and live online with a shipped ingredient kit.',
  founder: [
    { '@type': 'Person', name: 'Endri Cerhozi', jobTitle: 'Head Chef', sameAs: 'https://endricerhozi.com' },
    { '@type': 'Person', name: 'Marsel', jobTitle: 'Head Chef' },
  ],
  url: SITE,
  image: `${SITE}/images/cooking-class.jpg`,
  email: 'ciao@handmadepastaflorence.com',
  telephone: '+393445204379',
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via dei Pastai 12',
    addressLocality: 'Firenze',
    addressRegion: 'FI',
    addressCountry: 'IT',
  },
  areaServed: [
    { '@type': 'City', name: 'Florence' },
    { '@type': 'Place', name: 'Tuscany, Italy' },
  ],
  availableLanguage: [
    { '@type': 'Language', name: 'English' },
    { '@type': 'Language', name: 'Italian' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '10:00',
      closes: '21:00',
    },
  ],
};

// One Product + Offer per bookable experience — the simplest reliable path to
// price showing in search results. Prices mirror the on-page cards. Offer URLs
// point at the dedicated landing pages, which carry their own richer Product
// schema — so these summary products render on the homepage only.
const classes = [
  {
    name: 'The Chef’s Table',
    desc: 'Three hands-on hours in our Oltrarno kitchen — four pasta shapes, ending in a long Tuscan lunch.',
    price: '95',
    img: '/images/cooking_class_with_guests_in_picture.webp',
    url: '/pasta-making-class-florence/',
  },
  {
    name: 'Mercato & Mani',
    desc: 'Shop Sant’Ambrogio market at dawn with Endri or Marsel, then cook ravioli, a ragù and a seasonal dolce.',
    price: '145',
    img: '/images/aperitivo.webp',
    url: '/market-tour-cooking-class-florence/',
  },
  {
    name: 'The Family Long-Table',
    desc: 'Book the whole kitchen for a private celebration — birthdays, proposals, reunions.',
    price: '680',
    img: '/images/wedding-cake-2.webp',
    url: '/private-cooking-class-florence/',
  },
  {
    name: 'Live Online Pasta Class',
    desc: 'Cook live from anywhere with a fresh-pasta ingredient kit shipped to your door.',
    price: '68',
    img: '/images/cooking-class.jpg',
    url: '/online-pasta-making-class/',
  },
];

const products = classes.map((c) => ({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${c.name} — Pasta Class in Florence`,
  description: c.desc,
  image: `${SITE}${c.img}`,
  brand: { '@type': 'Brand', name: 'Handmade Pasta Florence' },
  offers: {
    '@type': 'Offer',
    price: c.price,
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    url: `${SITE}${c.url}`,
  },
}));

const isHome = Astro.url.pathname === '/';
---

<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
{isHome && products.map((p) => <script type="application/ld+json" set:html={JSON.stringify(p)} />)}
