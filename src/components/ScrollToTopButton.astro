---
const lang = Astro.currentLocale || 'en';
---

<button id="scroll-top" class="stt-button" type="button" aria-label={lang === 'it' ? 'Torna su' : 'Scroll to top'}>
  <svg
    class="stt-icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="m5 12 7-7 7 7" />
    <path d="M12 19V5" />
  </svg>
</button>

<style>
  /* sits directly above the WhatsApp button:
     bottom = 1.5rem edge + 3rem WA height + 0.75rem gap */
  .stt-button {
    position: fixed;
    bottom: calc(1.5rem + var(--fab-clearance, 0px));
    right: 1.5rem;
    z-index: 50;

    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    background-color: #111827;
    color: #fff;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);

    opacity: 0;
    transform: translateY(1rem);
    pointer-events: none;
    transition: all 300ms ease;
  }

  .stt-button:hover {
    background-color: #1f2937;
  }

  .stt-button.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .stt-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .stt-button {
      transition: none;
    }
  }
</style>

<script>
  const setup = () => {
    const btn = document.getElementById("scroll-top");
    if (!btn) return;

    const onScroll = () => {
      btn.classList.toggle("is-visible", window.scrollY > 300);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  };

  setup();
  document.addEventListener("astro:after-swap", setup);
</script>
