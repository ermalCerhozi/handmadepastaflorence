---
// Frictionless booking — fullscreen "order-ticket" modal. 4 steps, live pricing,
// calendar, timezone detection, add-on toggles, wallet checkout.
---

<div class="ek" data-booking hidden>
  <div class="ek__scrim" data-close-booking></div>
  <div class="ek__sheet" role="dialog" aria-modal="true" aria-label="Prenota un corso">
    <!-- top bar -->
    <header class="ek__top">
      <span class="ek__brand mono">Pasta Firenze · Scontrino N°—<span data-ticket>0042</span></span>
      <ol class="ek__steps mono" data-steps>
        <li class="on" data-dot="1">Esperienza</li>
        <li data-dot="2">Data &amp; ora</li>
        <li data-dot="3">Su misura</li>
        <li data-dot="4">Pagamento</li>
      </ol>
      <button class="ek__x" data-close-booking aria-label="Chiudi">✕</button>
    </header>
    <div class="ek__rail"><span data-progress></span></div>

    <div class="ek__body">
      <!-- left: steps -->
      <div class="ek__main">
        <section class="ek__view on" data-view="1">
          <p class="ek__kick mono">01 — Esperienza</p>
          <h2 class="ek__h">Come vuoi <em class="ser">cucinare?</em></h2>
          <div class="ek__choices">
            <button class="ch" data-choice="florence" data-price="95" data-hot>
              <span class="ch__big ser">In persona</span>
              <span class="ch__t">A Firenze</span>
              <span class="ch__d">Tre ore con le mani in pasta nella nostra cucina in Oltrarno, fino al pranzo.</span>
              <span class="ch__p">da €95<small>/persona</small></span>
              <span class="ch__tick">✓</span>
            </button>
            <button class="ch" data-choice="online" data-price="68" data-hot>
              <span class="ch__big ser">In diretta</span>
              <span class="ch__t">Online, ovunque</span>
              <span class="ch__d">Cucini live da casa con il kit spedito alla tua porta.</span>
              <span class="ch__p">da €68<small>/persona</small></span>
              <span class="ch__tick">✓</span>
            </button>
          </div>

          <!-- Ospiti qui: il prezzo non è mai una sorpresa -->
          <div class="qty2" data-qty-block hidden>
            <span class="qty2__info"><span class="qty2__l">Quanti ospiti?</span><span class="qty2__hint mono" data-qty-hint>—</span></span>
            <div class="qty2__c"><button data-qty="-1" aria-label="Meno">−</button><strong data-qty-val>1</strong><button data-qty="1" aria-label="Più">+</button></div>
          </div>
        </section>

        <section class="ek__view" data-view="2">
          <p class="ek__kick mono">02 — Data &amp; ora</p>
          <h2 class="ek__h">Quando ci <em class="ser">vediamo?</em></h2>
          <div class="cal2">
            <div class="cal2__bar"><button class="cal2__nav" data-cal-prev aria-label="Mese precedente">←</button><strong data-cal-label>—</strong><button class="cal2__nav" data-cal-next aria-label="Mese successivo">→</button></div>
            <div class="cal2__dow mono"><span>L</span><span>M</span><span>M</span><span>G</span><span>V</span><span>S</span><span>D</span></div>
            <div class="cal2__grid" data-cal-grid></div>
          </div>
          <div class="slots2" data-slots hidden>
            <p class="slots2__l mono">Orari disponibili <span data-slot-date></span></p>
            <div class="slots2__row" data-slot-row></div>
            <div class="tz2" data-tz hidden>
              <span class="tz2__c"><i class="mono">🇮🇹 Firenze</i><b data-tz-florence>—</b></span>
              <span class="tz2__arr">→</span>
              <span class="tz2__c"><i class="mono" data-tz-name>La tua ora</i><b data-tz-local>—</b></span>
            </div>
          </div>
        </section>

        <section class="ek__view" data-view="3">
          <p class="ek__kick mono">03 — Su misura</p>
          <h2 class="ek__h">Aggiungi un <em class="ser">tocco.</em></h2>
          <p class="ek__optnote mono">Facoltativo — solo extra.</p>
          <div class="adds2">
            <label class="ad" data-addon="kit" data-add-price="34" data-per="order" data-online-only>
              <span><span class="ad__t">Spedisci il kit ingredienti</span><span class="ad__d">Farina 00, semola, matterello e schede ricetta, refrigerati a casa tua.</span></span>
              <span class="ad__p">+€34</span><span class="sw"><input type="checkbox" /><span class="sw__tr"></span></span>
            </label>
            <label class="ad" data-addon="wine" data-add-price="18" data-per="guest">
              <span><span class="ad__t">Abbinamento vino</span><span class="ad__d">Due calici toscani scelti per il tuo menù (in persona) o una bottiglia spedita (online).</span></span>
              <span class="ad__p">+€18<small>/persona</small></span><span class="sw"><input type="checkbox" /><span class="sw__tr"></span></span>
            </label>
            <label class="ad" data-addon="gf" data-add-price="0" data-per="order">
              <span><span class="ad__t">Preferenza senza glutine</span><span class="ad__d">Prepariamo una miscela GF dedicata e una postazione pulita. Gratis.</span></span>
              <span class="ad__p">Gratis</span><span class="sw"><input type="checkbox" /><span class="sw__tr"></span></span>
            </label>
          </div>
        </section>

        <section class="ek__view" data-view="4">
          <p class="ek__kick mono">04 — Pagamento</p>
          <h2 class="ek__h">Ci siamo <em class="ser">quasi.</em></h2>
          <div class="pay2">
            <button class="pay2__w pay2__w--apple"> Pay</button>
            <button class="pay2__w pay2__w--g">G&nbsp;Pay</button>
          </div>
          <div class="pay2__or mono"><span>oppure carta</span></div>
          <div class="cf">
            <label class="fl fl--full"><span class="mono">Email per la conferma</span><input type="email" placeholder="tu@esempio.com" /></label>
            <label class="fl fl--full"><span class="mono">Numero carta</span><input inputmode="numeric" placeholder="1234  5678  9012  3456" /></label>
            <label class="fl"><span class="mono">Scadenza</span><input placeholder="MM / AA" /></label>
            <label class="fl"><span class="mono">CVC</span><input inputmode="numeric" placeholder="123" /></label>
          </div>
          <p class="pay2__trust mono">🔒 Protetto da Stripe · disdetta gratuita fino a 72h prima</p>
        </section>
      </div>

      <!-- right: sticky receipt -->
      <aside class="ek__receipt">
        <p class="rec__title mono">Lo scontrino</p>
        <ul class="rec__lines" data-summary-lines></ul>
        <div class="rec__total"><span class="mono">Totale</span><strong data-total>€0</strong></div>
        <div class="ek__actions">
          <button class="ek__back" data-prev hidden>← Indietro</button>
          <button class="ek__next" data-next disabled>Continua</button>
        </div>
        <p class="rec__note mono">Conferma immediata · posti limitati</p>
      </aside>
    </div>
  </div>
</div>

<script>
  type State = { step: number; experience: 'florence'|'online'|null; basePrice: number; date: string|null; time: string|null; guests: number; addons: Record<string, number>; };
  const setupBooking = () => {
    const root = document.querySelector<HTMLElement>('[data-booking]');
    if (!root) return;
    const MIN_GUESTS = 1, MAX_GUESTS = 14;
    const state: State = { step: 1, experience: null, basePrice: 0, date: null, time: null, guests: MIN_GUESTS, addons: {} };
    const $ = <T extends Element = HTMLElement>(s: string, r: ParentNode = root) => r.querySelector<T>(s);
    const $$ = <T extends Element = HTMLElement>(s: string, r: ParentNode = root) => Array.from(r.querySelectorAll<T>(s));

    const open = (prefill?: string|null) => {
      root.hidden = false; document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => root.classList.add('open'));
      if (prefill === 'florence' || prefill === 'online') $(`[data-choice="${prefill}"]`)?.click();
    };
    const close = () => { root.classList.remove('open'); document.body.style.overflow = ''; setTimeout(() => { root.hidden = true; }, 420); };
    document.querySelectorAll('[data-open-booking]').forEach((b) => b.addEventListener('click', () => open((b as HTMLElement).dataset.prefill)));
    $$('[data-close-booking]').forEach((b) => b.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !root.hidden) close(); });

    const goTo = (n: number) => {
      state.step = Math.min(4, Math.max(1, n));
      $$('[data-view]').forEach((v) => v.classList.toggle('on', v.dataset.view === String(state.step)));
      $$('[data-dot]').forEach((d) => { const dn = Number(d.dataset.dot); d.classList.toggle('on', dn === state.step); d.classList.toggle('done', dn < state.step); });
      const p = $('[data-progress]'); if (p) p.style.transform = `scaleX(${state.step / 4})`;
      const back = $('[data-prev]'); if (back) back.hidden = state.step === 1;
      const next = $<HTMLButtonElement>('[data-next]'); if (next) next.textContent = state.step === 4 ? 'Conferma & paga' : 'Continua';
      const main = $('.ek__main'); if (main) main.scrollTop = 0;
      validate();
    };
    const validate = () => {
      const next = $<HTMLButtonElement>('[data-next]'); if (!next) return;
      let ok = true;
      if (state.step === 1) ok = !!state.experience;
      if (state.step === 2) ok = !!state.date && !!state.time;
      next.disabled = !ok;
    };
    $('[data-next]')?.addEventListener('click', () => {
      if (state.step === 4) { const n = $<HTMLButtonElement>('[data-next]')!; n.textContent = 'Prenotato! 🎉'; n.disabled = true; return; }
      goTo(state.step + 1);
    });
    $('[data-prev]')?.addEventListener('click', () => goTo(state.step - 1));

    const qtyBlock = $('[data-qty-block]');
    const qtyHint = $('[data-qty-hint]');
    $$('[data-choice]').forEach((btn) => btn.addEventListener('click', () => {
      $$('[data-choice]').forEach((b) => b.classList.remove('sel'));
      btn.classList.add('sel');
      state.experience = btn.dataset.choice as 'florence'|'online';
      state.basePrice = Number(btn.dataset.price);
      if (qtyBlock) qtyBlock.hidden = false;
      if (qtyHint) qtyHint.textContent = `€${state.basePrice} a persona`;
      // extra solo-online: nascondi per "in persona" e rimuovi dallo stato
      $$('[data-online-only]').forEach((a) => {
        const el = a as HTMLElement; const show = state.experience === 'online';
        el.style.display = show ? '' : 'none';
        if (!show) {
          const key = el.dataset.addon!; const input = el.querySelector<HTMLInputElement>('input');
          if (input?.checked) { input.checked = false; el.classList.remove('on'); }
          delete state.addons[key];
        }
      });
      validate(); render();
    }));

    const setGuests = (n: number) => {
      state.guests = Math.min(MAX_GUESTS, Math.max(MIN_GUESTS, n));
      const val = $('[data-qty-val]'); if (val) val.textContent = String(state.guests);
      $$<HTMLButtonElement>('[data-qty]').forEach((b) => {
        const dir = Number(b.dataset.qty);
        b.disabled = (dir < 0 && state.guests === MIN_GUESTS) || (dir > 0 && state.guests === MAX_GUESTS);
      });
      render();
    };

    const today = new Date(); today.setHours(0,0,0,0);
    let view = new Date(today.getFullYear(), today.getMonth(), 1);
    const M = ['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];

    // Orari in ora di Firenze (Europe/Rome).
    const TIMES = ['10:00','14:30','18:00'];
    // Offset in minuti (a est di UTC) di un istante in un fuso — gestisce CET/CEST.
    const zoneOffset = (instant: Date, tz: string) => {
      const dtf = new Intl.DateTimeFormat('en-US', { timeZone: tz, hour12: false, year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const p: Record<string, string> = {};
      for (const part of dtf.formatToParts(instant)) p[part.type] = part.value;
      const asUTC = Date.UTC(+p.year, +p.month - 1, +p.day, +p.hour, +p.minute, +p.second);
      return Math.round((asUTC - instant.getTime()) / 60000);
    };
    // Istante assoluto (ms) di uno slot in ora di Firenze in un dato giorno.
    const slotMs = (date: Date, time: string) => {
      const [h, m] = time.split(':').map(Number);
      const guess = Date.UTC(date.getFullYear(), date.getMonth(), date.getDate(), h, m);
      return guess - zoneOffset(new Date(guess), 'Europe/Rome') * 60000;
    };
    const hasFutureSlot = (date: Date) => TIMES.some((t) => slotMs(date, t) > Date.now());
    const buildCal = () => {
      const grid = $('[data-cal-grid]')!; const label = $('[data-cal-label]')!;
      label.textContent = `${M[view.getMonth()]} ${view.getFullYear()}`; grid.innerHTML = '';
      const first = new Date(view.getFullYear(), view.getMonth(), 1);
      const off = (first.getDay() + 6) % 7;
      const days = new Date(view.getFullYear(), view.getMonth()+1, 0).getDate();
      for (let i=0;i<off;i++) grid.appendChild(document.createElement('span'));
      for (let d=1; d<=days; d++) {
        const cell = document.createElement('button'); const date = new Date(view.getFullYear(), view.getMonth(), d);
        cell.textContent = String(d); cell.className = 'cal2__day';
        const past = date < today; const closed = date.getDay() === 1;
        const elapsed = date.getTime() === today.getTime() && !hasFutureSlot(date); // oggi, slot finiti
        if (past || closed || elapsed) { cell.disabled = true; cell.classList.add('off'); }
        else cell.addEventListener('click', () => {
          $$('.cal2__day').forEach((c) => c.classList.remove('sel')); cell.classList.add('sel');
          state.date = date.toLocaleDateString('it-IT', { weekday: 'short', month: 'short', day: 'numeric' });
          state.time = null; showSlots(date); validate(); render();
        });
        grid.appendChild(cell);
      }
    };
    $('[data-cal-prev]')?.addEventListener('click', () => { const m = new Date(view.getFullYear(), view.getMonth()-1, 1); if (m >= new Date(today.getFullYear(), today.getMonth(), 1)) { view = m; buildCal(); } });
    $('[data-cal-next]')?.addEventListener('click', () => { view = new Date(view.getFullYear(), view.getMonth()+1, 1); buildCal(); });

    const showSlots = (date: Date) => {
      const w = $('[data-slots]')!; w.hidden = false; $('[data-slot-date]')!.textContent = `· ${state.date}`;
      const row = $('[data-slot-row]')!; row.innerHTML = '';
      TIMES.forEach((t) => { const b = document.createElement('button'); b.className = 'slot2'; b.textContent = t;
        if (slotMs(date, t) <= Date.now()) { b.disabled = true; b.classList.add('off'); } // orario già passato oggi
        else b.addEventListener('click', () => { $$('.slot2').forEach((s) => s.classList.remove('sel')); b.classList.add('sel'); state.time = t; showTz(date, t); validate(); render(); });
        row.appendChild(b); });
      $('[data-tz]')!.hidden = true;
    };
    const showTz = (date: Date, time: string) => {
      const tz = $('[data-tz]')!; tz.hidden = false;
      // Converte lo slot di Firenze nell'ora locale del visitatore, corretto tutto l'anno (CET/CEST).
      const instant = new Date(slotMs(date, time));
      const name = Intl.DateTimeFormat().resolvedOptions().timeZone || 'La tua ora';
      $('[data-tz-florence]')!.textContent = time;
      $('[data-tz-name]')!.textContent = name.replace(/_/g, ' ');
      $('[data-tz-local]')!.textContent = instant.toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit' });
    };

    $$('[data-addon]').forEach((label) => {
      const input = label.querySelector<HTMLInputElement>('input')!;
      input.addEventListener('change', () => {
        const key = (label as HTMLElement).dataset.addon!; const price = Number((label as HTMLElement).dataset.addPrice);
        label.classList.toggle('on', input.checked);
        if (input.checked) state.addons[key] = price; else delete state.addons[key];
        render();
      });
    });
    $$('[data-qty]').forEach((b) => b.addEventListener('click', () => setGuests(state.guests + Number((b as HTMLElement).dataset.qty))));

    const euro = (n: number) => `€${n.toLocaleString('it-IT')}`;
    const ADDON_LABELS: Record<string,string> = { kit: 'Kit ingredienti', wine: 'Vino', gf: 'Senza glutine' };
    const render = () => {
      const lines = $('[data-summary-lines]'); if (!lines) return;
      lines.innerHTML = '';
      const add = (l: string, a: number) => { const li = document.createElement('li'); li.innerHTML = `<span>${l}</span><span>${a === 0 ? 'Gratis' : euro(a)}</span>`; lines.appendChild(li); };
      let total = 0;
      if (state.experience) {
        const sub = state.basePrice * state.guests; total += sub;
        const name = state.experience === 'florence' ? 'In persona' : 'In diretta';
        add(`${name} · €${state.basePrice} × ${state.guests} ${state.guests === 1 ? 'ospite' : 'ospiti'}`, sub);
      }
      $$('[data-addon]').forEach((label) => {
        const el = label as HTMLElement; const key = el.dataset.addon!;
        if (!(key in state.addons)) return;
        const amt = el.dataset.per === 'guest' ? state.addons[key] * state.guests : state.addons[key];
        total += amt; add(ADDON_LABELS[key] ?? key, amt);
      });
      if (state.date) add(`${state.date}${state.time ? ' · ' + state.time : ''}`, 0);
      if (!lines.children.length) add('Niente ancora…', 0);
      const totalEl = $('[data-total]'); if (totalEl) totalEl.textContent = euro(total);
    };

    buildCal(); setGuests(MIN_GUESTS); goTo(1); render();
  };
  setupBooking();
  document.addEventListener('astro:after-swap', setupBooking);
</script>

<style>
  .ek { position: fixed; inset: 0; z-index: 1000; }
  .ek[hidden] { display: none; }
  .ek__scrim { position: absolute; inset: 0; background: rgba(33,28,23,0.7); opacity: 0; transition: opacity 0.4s var(--ease); }
  .ek.open .ek__scrim { opacity: 1; }
  .ek__sheet {
    position: absolute; inset: clamp(0px, 2vw, 28px); background: var(--paper-2); border: var(--rule);
    display: flex; flex-direction: column; overflow: hidden; box-shadow: 12px 12px 0 var(--pomodoro);
    transform: translateY(24px) scale(0.98); opacity: 0; transition: transform 0.45s var(--ease), opacity 0.4s var(--ease);
  }
  .ek.open .ek__sheet { transform: none; opacity: 1; }
  @media (max-width: 640px) { .ek__sheet { inset: 0; box-shadow: none; } }

  .ek__top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.9rem var(--gutter); border-bottom: var(--rule); flex-wrap: wrap; }
  .ek__brand { color: var(--ink-soft); }
  .ek__steps { display: flex; gap: 0.9rem; flex-wrap: wrap; }
  .ek__steps li { color: var(--ink-soft); opacity: 0.45; }
  .ek__steps li.on { opacity: 1; color: var(--pomodoro); }
  .ek__steps li.done { opacity: 0.85; }
  .ek__steps li.done::after { content: ' ✓'; }
  .ek__x { width: 38px; height: 38px; border: var(--rule); border-radius: 50%; transition: background 0.25s, color 0.25s, transform 0.3s; }
  .ek__x:hover { background: var(--ink); color: var(--cream); transform: rotate(90deg); }
  .ek__rail { height: 4px; background: var(--paper-3); border-bottom: var(--rule); }
  .ek__rail span { display: block; height: 100%; background: var(--pomodoro); transform-origin: left; transform: scaleX(0.25); transition: transform 0.5s var(--ease); }

  .ek__body { flex: 1; display: grid; grid-template-columns: 1fr; overflow: hidden; }
  @media (min-width: 820px) { .ek__body { grid-template-columns: 1.5fr 0.9fr; } }
  .ek__main { overflow-y: auto; padding: clamp(1.4rem, 3vw, 2.6rem) var(--gutter); }
  .ek__view { display: none; animation: vin 0.45s var(--ease) both; }
  .ek__view.on { display: block; }
  @keyframes vin { from { opacity: 0; transform: translateX(16px); } to { opacity: 1; transform: none; } }
  .ek__kick { color: var(--pomodoro); }
  .ek__h { font-size: var(--t-2); margin: 0.4rem 0 1.6rem; } .ek__h em { color: var(--pomodoro); font-weight: 500; }

  .ek__choices { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 560px) { .ek__choices { grid-template-columns: 1fr 1fr; } }
  .ch { position: relative; text-align: left; display: grid; gap: 0.3rem; padding: 1.4rem; background: var(--cream); border: var(--rule); box-shadow: 5px 5px 0 var(--ink); transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease); }
  .ch:hover { transform: translate(-3px,-3px); box-shadow: 8px 8px 0 var(--ink); }
  .ch.sel { box-shadow: 5px 5px 0 var(--pomodoro); border-color: var(--pomodoro); }
  .ch__big { font-size: 1.9rem; color: var(--pomodoro); }
  .ch__t { font-family: var(--display); font-weight: 800; text-transform: uppercase; font-size: var(--t-1); }
  .ch__d { font-family: var(--display); font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--ink-soft); font-size: var(--t--1); line-height: 1.4; }
  .ch__p { font-family: var(--serif); font-style: italic; font-size: 1.4rem; margin-top: 0.4rem; } .ch__p small { font-size: 0.8rem; color: var(--ink-soft); }
  .ch__tick { position: absolute; top: 1rem; right: 1rem; width: 26px; height: 26px; border-radius: 50%; background: var(--pomodoro); color: var(--cream); display: grid; place-content: center; font-size: 0.8rem; opacity: 0; transform: scale(0.4); transition: 0.3s var(--ease-back); }
  .ch.sel .ch__tick { opacity: 1; transform: none; }

  .cal2 { background: var(--cream); border: var(--rule); padding: 1.1rem; }
  .cal2__bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.8rem; }
  .cal2__bar strong { font-family: var(--serif); font-style: italic; font-weight: 500; font-size: var(--t-1); text-transform: none; }
  .cal2__nav { width: 36px; height: 36px; border: 2px solid var(--ink); border-radius: 50%; transition: background 0.2s, color 0.2s; }
  .cal2__nav:hover { background: var(--ink); color: var(--cream); }
  .cal2__dow, .cal2__grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .cal2__dow { margin-bottom: 4px; } .cal2__dow span { text-align: center; color: var(--ink-soft); }
  .cal2__day { aspect-ratio: 1; border: 1.5px solid transparent; font-weight: 700; font-size: 0.85rem; transition: background 0.18s, color 0.18s, border-color 0.18s, transform 0.18s; }
  .cal2__day:not(.off):hover { background: var(--saffron); border-color: var(--ink); transform: scale(1.06); }
  .cal2__day.off { color: var(--paper-3); opacity: 0.6; text-decoration: line-through; cursor: not-allowed; }
