---
const year = new Date().getFullYear();
---
<footer class="eft">
  <div class="wrap">
    <div class="eft__cta">
      <h2 class="eft__h ghost" data-ghost="Mani in pasta?">Mani in <em class="ser">pasta?</em></h2>
      <button class="ebtn ebtn--solid" data-open-booking data-hot>Prenota ora ↗</button>
    </div>

    <div class="eft__grid">
      <div class="eft__brand">
        <span class="eft__seal seal">EST<br/>’78</span>
        <p class="eft__name">Pasta<em class="ser">Firenze</em></p>
        <p class="mono eft__addr">Via dei Pastai 12 · Oltrarno · Firenze</p>
      </div>
      <nav class="eft__col">
        <h3 class="mono">Corsi</h3>
        <a href="#courses">In persona</a><a href="#online">Online</a><a href="#shapes">Le forme</a><a href="#" data-open-booking>Regala</a>
      </nav>
      <nav class="eft__col">
        <h3 class="mono">Visita</h3>
        <a href="#">Eventi privati</a><a href="#">FAQ</a><a href="mailto:ciao@handmadepastaflorence.com">Scrivici</a><a href="/">Versione I ↖</a>
      </nav>
      <nav class="eft__col">
        <h3 class="mono">Seguici</h3>
        <a href="#">Instagram</a><a href="#">YouTube</a><a href="#">Tripadvisor</a><a href="#">Newsletter</a>
      </nav>
    </div>

    <div class="eft__base mono">
      <span>© {year} Handmade Pasta Florence · P.IVA 0123456789</span>
      <span class="eft__made">Stampato e impastato a mano 🤌 a Firenze</span>
    </div>
  </div>
</footer>

<style>
  .eft { background: var(--pomodoro); color: var(--cream); padding-block: clamp(3rem, 8vh, 5rem) 2rem; }
  .eft__cta { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 2rem; padding-bottom: clamp(2.5rem, 6vw, 4rem); border-bottom: 2.5px solid var(--cream); }
  .eft__h { font-size: var(--t-4); } .eft__h em { color: var(--ink); font-weight: 500; }
  .eft__h.ghost::before { color: var(--ink); -webkit-text-fill-color: var(--ink); }
  .eft .ebtn--solid { background: var(--cream); color: var(--ink); box-shadow: 5px 5px 0 var(--ink); }
  .eft .ebtn--solid:hover { box-shadow: 7px 7px 0 var(--ink); }

  .eft__grid { display: grid; gap: 2rem; padding-block: clamp(2.5rem, 6vw, 4rem); grid-template-columns: repeat(auto-fit, minmax(min(100%, 170px), 1fr)); }
  .eft__seal { width: 50px; height: 50px; background: var(--cream); color: var(--ink); border-color: var(--cream); font-size: 0.55rem; line-height: 1; transform: rotate(-6deg); margin-bottom: 0.8rem; }
  .eft__name { font-family: var(--display); font-weight: 800; text-transform: uppercase; font-size: 1.5rem; line-height: 0.9; }
  .eft__name em { display: block; font-size: 1rem; color: var(--ink); }
  .eft__addr { color: rgba(247,240,223,0.7); margin-top: 0.6rem; }
  .eft__col h3 { color: var(--ink); margin-bottom: 1rem; }
  .eft__col a { display: block; padding-block: 0.35rem; color: rgba(247,240,223,0.85); transition: padding-left 0.3s, color 0.3s; }
  .eft__col a:hover { padding-left: 6px; color: var(--cream); }
  .eft__base { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 1rem; padding-top: 2rem; border-top: 2.5px solid rgba(247,240,223,0.3); color: rgba(247,240,223,0.7); }
  .eft__made { color: var(--ink); }
</style>
