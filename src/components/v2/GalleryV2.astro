---
const shapes = [
  { name: 'Pappardelle', region: 'Firenze · Toscana', blurb: 'Nastri larghi e vellutati — da “pappare”, divorare.', hist: 'Nate nella campagna toscana per raccogliere ricchi ragù di cinghiale e lepre. La larghezza è il punto: ogni nastro porta con sé un cucchiaio di sugo.', teaches: 'La Tavola della Nonna' },
  { name: 'Ravioli', region: 'Tutta Italia', blurb: 'Fagottini pizzicati attorno a ricotta, spinaci o zucca.', hist: 'Citati nelle lettere di un mercante toscano del Trecento, i ravioli nascono per non sprecare il formaggio. Sigillarli bene è un’arte — l’aria è il nemico.', teaches: 'Mercato & Mani' },
  { name: 'Pici', region: 'Siena · Val d’Orcia', blurb: 'Spaghettoni grossi tirati a mano, uno per uno.', hist: 'Pasta povera di sola farina e acqua, arrotolata a mano sul tagliere. Nessuno è identico all’altro, ed è proprio quell’irregolarità a trattenere il sugo.', teaches: 'La Tavola della Nonna' },
  { name: 'Tortelli', region: 'Mugello', blurb: 'Cuscini paffuti ripieni di patata, dalle colline a nord.', hist: 'La risposta del Mugello a una sera fredda: patata, parmigiano e noce moscata, conditi con burro e salvia o un ragù di carne.', teaches: 'La Tavolata Privata' },
  { name: 'Tagliatelle', region: 'Emilia & Toscana', blurb: 'Il nastro all’uovo, tagliato preciso a un dito.', hist: 'La leggenda lega i suoi nastri dorati ai capelli rinascimentali; la verità è più umile. Tirata sottile, piegata e tagliata a mano — la prima forma che ogni nonna insegna.', teaches: 'Diretta · Pasta all’Uovo' },
];
---

<section class="gal2" id="forme">
  <div class="wrap gal2__head">
    <div data-reveal>
      <span class="tag">Catalogo delle forme</span>
      <h2 class="gal2__title">Le <em class="ser">forme.</em></h2>
    </div>
    <p class="gal2__hint mono" data-reveal>Trascina · scorri · tocca una forma per la sua storia</p>
  </div>

  <div class="gal2__track" data-gtrack>
    {shapes.map((s, i) => (
      <article class="card2" data-card data-hot>
        <button class="card2__front" data-flip aria-expanded="false">
          <span class="card2__no ser">{String(i + 1).padStart(2, '0')}</span>
          <span class="card2__disc"><span class="card2__lines"></span></span>
          <h3 class="card2__name">{s.name}</h3>
          <span class="card2__region mono">{s.region}</span>
          <p class="card2__blurb">{s.blurb}</p>
          <span class="card2__more mono">La storia ↘</span>
        </button>
        <div class="card2__back">
          <h4 class="card2__bname">{s.name}</h4>
          <p class="card2__hist">{s.hist}</p>
          <div class="card2__teach"><span class="mono">Si impara in</span><strong>{s.teaches}</strong></div>
          <button class="card2__book" data-open-booking>Prenota ↗</button>
          <button class="card2__close mono" data-flip>← torna</button>
        </div>
      </article>
    ))}
  </div>

  <div class="wrap gal2__ctrl">
    <div class="gal2__bar"><span data-gbar></span></div>
    <div class="gal2__arr"><button data-gp aria-label="Indietro">←</button><button data-gn aria-label="Avanti">→</button></div>
  </div>
</section>

<script>
  const setGal = () => {
    const tr = document.querySelector<HTMLElement>('[data-gtrack]');
    if (!tr) return;
    document.querySelectorAll<HTMLElement>('[data-card]').forEach((c) => {
      c.querySelectorAll<HTMLButtonElement>('[data-flip]').forEach((b) => b.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = c.classList.toggle('flip');
        c.querySelector('[data-flip]')?.setAttribute('aria-expanded', String(open));
      }));
    });
    const step = () => { const f = tr.querySelector<HTMLElement>('[data-card]'); return f ? f.offsetWidth + 22 : 320; };
    document.querySelector('[data-gp]')?.addEventListener('click', () => tr.scrollBy({ left: -step(), behavior: 'smooth' }));
    document.querySelector('[data-gn]')?.addEventListener('click', () => tr.scrollBy({ left: step(), behavior: 'smooth' }));
    const bar = document.querySelector<HTMLElement>('[data-gbar]');
    tr.addEventListener('scroll', () => { if (!bar) return; const m = tr.scrollWidth - tr.clientWidth; bar.style.transform = `scaleX(${0.1 + (m > 0 ? tr.scrollLeft / m : 0) * 0.9})`; }, { passive: true });
    let d = false, sx = 0, sl = 0;
    tr.addEventListener('pointerdown', (e) => { d = true; sx = e.clientX; sl = tr.scrollLeft; tr.classList.add('drag'); });
    window.addEventListener('pointerup', () => { d = false; tr.classList.remove('drag'); });
    window.addEventListener('pointermove', (e) => { if (d) tr.scrollLeft = sl - (e.clientX - sx); });
  };
  setGal();
  document.addEventListener('astro:after-swap', setGal);
</script>

<style>
  .gal2 { padding-block: clamp(4rem, 11vh, 8rem); background: var(--paper-2); border-bottom: var(--rule); overflow: hidden; }
  .gal2__head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1.4rem; margin-bottom: 2.4rem; }
  .gal2__title { font-size: var(--t-3); margin-top: 1rem; } .gal2__title em { color: var(--pomodoro); font-weight: 500; }
  .gal2__hint { color: var(--ink-soft); }

  .gal2__track { display: flex; gap: 22px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; padding: 0.4rem var(--gutter) 1.4rem; cursor: none; }
  .gal2__track.drag { scroll-snap-type: none; }
  .gal2__track::-webkit-scrollbar { display: none; }

  .card2 { flex: 0 0 clamp(250px, 76vw, 330px); scroll-snap-align: center; aspect-ratio: 3/4; position: relative; perspective: 1400px; }
  .card2__front, .card2__back { position: absolute; inset: 0; border: var(--rule); backface-visibility: hidden; transition: transform 0.7s var(--ease); }
  .card2__front { background: var(--cream); display: flex; flex-direction: column; align-items: flex-start; text-align: left; padding: 1.4rem; gap: 0.35rem; box-shadow: 6px 6px 0 var(--ink); }
  .card2:hover .card2__front { box-shadow: 9px 9px 0 var(--pomodoro); transform: translate(-3px,-3px); }
  .card2.flip .card2__front { transform: rotateY(180deg); }
  .card2.flip .card2__back { transform: rotateY(0); }
  .card2__back { transform: rotateY(-180deg); background: var(--ink); color: var(--cream); display: flex; flex-direction: column; padding: 1.5rem; gap: 0.7rem; box-shadow: 6px 6px 0 var(--pomodoro); }

  .card2__no { position: absolute; top: 0.8rem; right: 1rem; font-size: 2rem; color: var(--pomodoro); }
  .card2__disc { width: 100%; aspect-ratio: 16/10; border: 2px solid var(--ink); position: relative; overflow: hidden; background: linear-gradient(135deg, var(--saffron), #c98810); }
  .card2:nth-child(2n) .card2__disc { background: linear-gradient(135deg, var(--pomodoro), var(--pomodoro-deep)); }
  .card2:nth-child(3n) .card2__disc { background: linear-gradient(135deg, var(--basilico), #2a3f27); }
  .card2__lines { position: absolute; inset: 0; background-image: repeating-linear-gradient(115deg, rgba(33,28,23,0.25) 0 3px, transparent 3px 12px); transition: transform 0.6s var(--ease); }
  .card2:hover .card2__lines { transform: translateX(10px); }
  .card2__name { font-size: var(--t-2); margin-top: 0.3rem; }
  .card2__region { color: var(--ink-soft); }
  .card2__blurb { font-family: var(--display); font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--ink-soft); font-size: var(--t-0); line-height: 1.4; margin-top: 0.2rem; }
  .card2__more { margin-top: auto; color: var(--pomodoro); }

  .card2__bname { color: var(--saffron); font-size: var(--t-2); }
  .card2__hist { font-family: var(--display); font-weight: 400; text-transform: none; letter-spacing: 0; font-size: var(--t-0); line-height: 1.5; color: rgba(247,240,223,0.85); flex: 1; }
  .card2__teach { border: 2px solid rgba(232,163,23,0.4); padding: 0.7rem 0.9rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .card2__teach span { color: rgba(247,240,223,0.55); }
  .card2__teach strong { font-family: var(--serif); font-style: italic; font-weight: 500; font-size: var(--t-1); text-transform: none; }
  .card2__book { background: var(--saffron); color: var(--ink); font-family: var(--display); font-weight: 800; text-transform: uppercase; padding: 0.7rem; border: 2px solid var(--ink); transition: transform 0.2s var(--ease); }
  .card2__book:hover { transform: translateY(-2px); }
  .card2__close { color: rgba(247,240,223,0.6); text-align: center; }

  .gal2__ctrl { display: flex; align-items: center; gap: 1.4rem; margin-top: 0.6rem; }
  .gal2__bar { flex: 1; height: 4px; background: var(--paper-3); border: 1.5px solid var(--ink); overflow: hidden; }
  .gal2__bar span { display: block; height: 100%; background: var(--pomodoro); transform-origin: left; transform: scaleX(0.1); transition: transform 0.12s linear; }
  .gal2__arr { display: flex; gap: 0.6rem; }
  .gal2__arr button { width: 46px; height: 46px; border: var(--rule); border-radius: 50%; font-size: 1.1rem; background: var(--paper); transition: background 0.25s, color 0.25s, transform 0.25s; }
  .gal2__arr button:hover { background: var(--ink); color: var(--cream); transform: scale(1.06); }
</style>
