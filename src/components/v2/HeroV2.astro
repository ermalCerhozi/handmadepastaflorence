---
---
<section class="hero" id="top">
  <!-- giant background watermark -->
  <span class="hero__mark ser" data-para="0.12" aria-hidden="true">Buon<br/>appetito</span>

  <div class="wrap hero__inner">
    <div class="hero__top mono" data-reveal>
      <span>Firenze, Italia</span>
      <span class="hero__top-mid">N°—01 · L’edizione fatta a mano</span>
      <span>43°46′N 11°15′E</span>
    </div>

    <h1 class="hero__title">
      <span class="hero__line ghost" data-ghost="Farina," data-reveal style="--d:80ms">Farina,</span>
      <span class="hero__line hero__line--em" data-reveal style="--d:200ms"><em class="ser">uova</em> e le</span>
      <span class="hero__line ghost" data-ghost="tue mani." data-reveal style="--d:320ms">tue mani.</span>
    </h1>

    <div class="hero__foot">
      <p class="hero__lede" data-reveal style="--d:440ms">
        Tre ore con le mani in pasta accanto a una vera nonna fiorentina —
        nella nostra cucina in Oltrarno, o in diretta online con il kit
        spedito a casa tua.
      </p>
      <div class="hero__cta-wrap" data-reveal style="--d:540ms">
        <button class="ebtn ebtn--solid" data-open-booking data-hot>
          Prenota il tuo posto <span>↗</span>
        </button>
        <a class="ebtn ebtn--out" href="#online" data-hot>Guarda il corso online</a>
      </div>
    </div>
  </div>

  <!-- rotating price seal sticker -->
  <div class="hero__sticker seal" data-para="-0.06">
    <span>Da<br/><strong>€68</strong><br/>a testa</span>
  </div>

  <a href="#courses" class="hero__scroll mono" aria-label="Scroll">Scorri ↓</a>
</section>

<style>
  .hero {
    position: relative; min-height: 100svh; display: flex; align-items: center;
    padding-top: clamp(6rem, 14vh, 9rem); padding-bottom: clamp(3rem, 8vh, 6rem);
    overflow: hidden; border-bottom: var(--rule);
  }
  .hero__mark {
    position: absolute; right: -2%; top: 8%; z-index: 0; line-height: 0.8;
    font-size: clamp(7rem, 26vw, 26rem); color: var(--paper-3); opacity: 0.55;
    text-align: right; pointer-events: none; font-weight: 500;
  }
  .hero__inner { display: flex; flex-direction: column; gap: clamp(1.6rem, 4vw, 3rem); }

  .hero__top { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding-bottom: 0.9rem; border-bottom: var(--rule); }
  .hero__top-mid { color: var(--pomodoro); }

  .hero__title { font-size: var(--t-5); font-weight: 800; letter-spacing: -0.04em; }
  .hero__line { display: block; }
  .hero__line--em { color: var(--ink); }
  .hero__line--em em { color: var(--pomodoro); font-weight: 500; }

  .hero__foot { display: grid; gap: 1.6rem; align-items: end; grid-template-columns: 1fr; max-width: 900px; }
  @media (min-width: 760px) { .hero__foot { grid-template-columns: 1.1fr 1fr; } }
  .hero__lede { font-family: var(--display); font-weight: 500; font-size: var(--t-1); line-height: 1.4; max-width: 42ch; text-transform: none; }
  .hero__cta-wrap { display: flex; flex-wrap: wrap; gap: 0.8rem; }

  .ebtn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: var(--display); font-weight: 800; text-transform: uppercase; letter-spacing: 0.02em;
    padding: 0.95rem 1.5rem; border: var(--rule); transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease), background 0.2s, color 0.2s;
  }
  .ebtn--solid { background: var(--ink); color: var(--cream); box-shadow: 5px 5px 0 var(--pomodoro); }
  .ebtn--solid span { transition: transform 0.3s var(--ease); }
  .ebtn--solid:hover { transform: translate(-2px,-2px); box-shadow: 7px 7px 0 var(--pomodoro); }
  .ebtn--solid:hover span { transform: translate(3px,-3px); }
  .ebtn--solid:active { transform: translate(2px,2px); box-shadow: 2px 2px 0 var(--pomodoro); }
  .ebtn--out { background: var(--paper); box-shadow: 5px 5px 0 var(--ink); }
  .ebtn--out:hover { background: var(--saffron); transform: translate(-2px,-2px); box-shadow: 7px 7px 0 var(--ink); }

  .hero__sticker {
    position: absolute; right: clamp(1rem, 6vw, 6rem); top: clamp(7rem, 16vh, 11rem); z-index: 2;
    width: clamp(92px, 14vw, 130px); height: clamp(92px, 14vw, 130px);
    background: var(--saffron); transform: rotate(9deg); animation: stickerwob 5s var(--ease) infinite;
  }
  .hero__sticker strong { font-family: var(--serif); font-style: italic; font-size: 1.7rem; }
  @keyframes stickerwob { 0%,100% { transform: rotate(9deg); } 50% { transform: rotate(4deg) scale(1.04); } }

  .hero__scroll {
    position: absolute; left: var(--gutter); bottom: 1.2rem; z-index: 2; color: var(--ink-soft);
    animation: scrollnudge 1.8s var(--ease) infinite;
  }
  @keyframes scrollnudge { 0%,100% { transform: translateY(0); } 50% { transform: translateY(5px); } }

  @media (max-width: 759px) {
    .hero__sticker { width: 84px; height: 84px; top: auto; bottom: 5rem; }
  }
</style>
