---
const inperson = [
  { n: '01', name: 'La Tavola della Nonna', meta: '3 ore · max 8 · Oltrarno', price: '95', desc: 'Quattro forme, un lungo pranzo. Tiri i pici, chiudi i tortelli, poi ti siedi a mangiare tutto con un calice di Chianti.' },
  { n: '02', name: 'Mercato & Mani', meta: '5 ore · max 6 · con mercato', price: '145', desc: 'Spesa all’alba al Sant’Ambrogio col cuoco, poi ravioli, ragù e un dolce di stagione in cucina.' },
  { n: '03', name: 'Tavolata Privata', meta: 'flessibile · 6–14 · sere', price: '680', desc: 'Prenoti tutta la cucina. Compleanni, proposte, riunioni — noi cuciniamo, voi festeggiate.', from: true },
];
const online = [
  { n: '01', name: 'Diretta · Pasta all’Uovo', meta: '90 min live · kit incluso · ogni fuso', price: '68', desc: 'Cucini in diretta con la nonna su uno streaming multi-camera. Il kit arriva refrigerato due giorni prima.' },
  { n: '02', name: 'Cofanetto Regalo', meta: 'riscatti quando vuoi · spedito 48h', price: '120', desc: 'Un voucher più un kit bellissimo — farina 00, semola, matterello e ricette — impacchettato e spedito.' },
  { n: '03', name: 'La Videoteca', meta: 'accesso a vita · forme nuove ogni mese', price: '39', desc: 'Dodici master-shapes da riguardare per sempre, con schede scaricabili e un filo diretto con la cucina.' },
];
---

<section class="menu" id="corsi">
  <div class="wrap">
    <div class="menu__head">
      <div data-reveal>
        <span class="tag">Il menù dei corsi</span>
        <h2 class="menu__title ghost" data-ghost="Scegli come">Scegli come<br/>mettere le mani <em class="ser">in pasta.</em></h2>
      </div>
      <div class="etoggle" data-reveal role="tablist" aria-label="Tipo di corso">
        <span class="etoggle__pill" data-pill></span>
        <button class="etoggle__o on" data-mode="inperson" role="tab" aria-selected="true" data-hot>In persona</button>
        <button class="etoggle__o" data-mode="online" role="tab" aria-selected="false" data-hot>Online</button>
      </div>
    </div>

    <div class="menu__list" data-panel="inperson">
      {inperson.map((c, i) => (
        <article class="row" data-reveal style={`--d:${i * 80}ms`} data-hot>
          <span class="row__n ser">{c.n}</span>
          <div class="row__main">
            <h3 class="row__name">{c.name}</h3>
            <p class="row__desc">{c.desc}</p>
          </div>
          <span class="row__meta mono">{c.meta}</span>
          <span class="row__price">{c.from ? 'da ' : ''}€{c.price}</span>
          <button class="row__go" data-open-booking data-prefill="florence" aria-label={`Prenota ${c.name}`}>↗</button>
        </article>
      ))}
    </div>

    <div class="menu__list hide" data-panel="online">
      {online.map((c, i) => (
        <article class="row" data-reveal style={`--d:${i * 80}ms`} data-hot>
          <span class="row__n ser">{c.n}</span>
          <div class="row__main">
            <h3 class="row__name">{c.name}</h3>
            <p class="row__desc">{c.desc}</p>
          </div>
          <span class="row__meta mono">{c.meta}</span>
          <span class="row__price">€{c.price}</span>
          <button class="row__go" data-open-booking data-prefill="online" aria-label={`Prenota ${c.name}`}>↗</button>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const setMenu = () => {
    const tg = document.querySelector('.etoggle');
    if (!tg) return;
    const opts = tg.querySelectorAll<HTMLButtonElement>('.etoggle__o');
    const pill = tg.querySelector<HTMLElement>('[data-pill]');
    const panels = document.querySelectorAll<HTMLElement>('[data-panel]');
    const move = (b: HTMLElement) => { if (pill) { pill.style.width = `${b.offsetWidth}px`; pill.style.transform = `translateX(${b.offsetLeft}px)`; } };
    const act = tg.querySelector<HTMLElement>('.etoggle__o.on');
    if (act) requestAnimationFrame(() => move(act));
    opts.forEach((b) => b.addEventListener('click', () => {
      opts.forEach((o) => { o.classList.remove('on'); o.setAttribute('aria-selected', 'false'); });
      b.classList.add('on'); b.setAttribute('aria-selected', 'true'); move(b);
      panels.forEach((p) => p.classList.toggle('hide', p.dataset.panel !== b.dataset.mode));
    }));
    window.addEventListener('resize', () => { const a = tg.querySelector<HTMLElement>('.etoggle__o.on'); if (a) move(a); });
  };
  setMenu();
  document.addEventListener('astro:after-swap', setMenu);
</script>

<style>
  .menu { padding-block: clamp(4rem, 11vh, 8rem); border-bottom: var(--rule); }
  .menu__head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1.6rem; margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .menu__title { font-size: var(--t-3); margin-top: 1rem; }
  .menu__title em { color: var(--pomodoro); font-weight: 500; }

  .etoggle { position: relative; display: inline-flex; border: var(--rule); background: var(--paper-2); box-shadow: 4px 4px 0 var(--ink); }
  .etoggle__pill { position: absolute; top: 0; left: 0; height: 100%; background: var(--pomodoro); z-index: 0; transition: transform 0.5s var(--ease), width 0.5s var(--ease); }
  .etoggle__o { position: relative; z-index: 1; padding: 0.8rem 1.4rem; font-family: var(--display); font-weight: 800; text-transform: uppercase; letter-spacing: 0.02em; transition: color 0.4s var(--ease); }
  .etoggle__o.on { color: var(--cream); }

  .menu__list { display: grid; animation: mpin 0.5s var(--ease) both; border-top: var(--rule); }
  .menu__list.hide { display: none; }
  @keyframes mpin { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

  .row {
    display: grid; align-items: center; gap: 0.4rem 1.4rem;
    grid-template-columns: auto 1fr auto auto auto;
    padding: clamp(1.1rem, 2.5vw, 1.8rem) 0; border-bottom: var(--rule);
    position: relative; transition: background 0.3s, padding-left 0.3s var(--ease);
  }
  .row::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 0; background: var(--saffron); z-index: -1; transition: width 0.4s var(--ease); }
  .row:hover { padding-left: 1.2rem; }
  .row:hover::before { width: 100%; }
  .row__n { font-size: clamp(1.6rem, 3vw, 2.6rem); color: var(--pomodoro); font-weight: 500; min-width: 1.6em; }
  .row__name { font-size: var(--t-1); }
  .row__desc { font-family: var(--display); font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--ink-soft); font-size: var(--t-0); line-height: 1.4; max-width: 52ch; margin-top: 0.2rem; }
  .row__meta { color: var(--ink-soft); white-space: nowrap; align-self: start; padding-top: 0.5rem; }
  .row__price { font-family: var(--serif); font-style: italic; font-size: clamp(1.4rem, 2.5vw, 2.2rem); white-space: nowrap; }
  .row__go {
    width: 50px; height: 50px; border: var(--rule); background: var(--paper); border-radius: 50%;
    font-size: 1.2rem; transition: transform 0.25s var(--ease), background 0.25s, color 0.25s; flex: none;
  }
  .row__go:hover { background: var(--ink); color: var(--cream); transform: rotate(45deg) scale(1.08); }

  @media (max-width: 860px) {
    .row { grid-template-columns: auto 1fr auto; grid-template-areas: 'n main go' 'n meta price'; row-gap: 0.6rem; }
    .row__n { grid-area: n; } .row__main { grid-area: main; } .row__meta { grid-area: meta; padding-top: 0; }
    .row__price { grid-area: price; text-align: right; } .row__go { grid-area: go; align-self: start; }
  }
</style>
