---
const ticker = [
  'Pasta fatta a mano dal 1978',
  'Oltrarno · Firenze',
  'In persona & online',
  'Kit spedito in tutto il mondo',
  '4.97 ★ · 2.300+ ospiti',
  'Prossimo corso: Sabato 10:00',
];
---

<div class="ticker" aria-hidden="true">
  <div class="ticker__track">
    {[0, 1].map(() => (
      <div class="ticker__group">
        {ticker.map((t) => (<span>{t}</span>))}
      </div>
    ))}
  </div>
</div>

<header class="nav" data-nav>
  <div class="wrap nav__inner">
    <a href="#top" class="nav__brand">
      <span class="nav__seal seal">EST<br />’78</span>
      <span class="nav__word">Pasta<em class="ser">Firenze</em></span>
    </a>
    <nav class="nav__links mono" aria-label="Primary">
      <a href="#courses">01 — Corsi</a>
      <a href="#online">02 — Online</a>
      <a href="#shapes">03 — Le Forme</a>
      <a href="/">↖ Versione I</a>
    </nav>
    <button class="nav__cta" data-open-booking data-hot>
      Prenota <span class="nav__cta-x">↗</span>
    </button>
  </div>
</header>

<script>
  const setNav = () => {
    const n = document.querySelector('[data-nav]');
    if (!n) return;
    const on = () => n.classList.toggle('stuck', window.scrollY > 60);
    window.addEventListener('scroll', on, { passive: true }); on();
  };
  setNav();
  document.addEventListener('astro:after-swap', setNav);
</script>

<style>
  .ticker {
    position: fixed; top: 0; left: 0; right: 0; z-index: 210;
    background: var(--ink); color: var(--cream); overflow: hidden;
    border-bottom: var(--rule);
  }
  .ticker__track { display: flex; width: max-content; animation: tick 32s linear infinite; }
  .ticker__group { display: flex; }
  .ticker__group span {
    font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.5rem 1.4rem; white-space: nowrap; position: relative;
  }
  .ticker__group span::after { content: '✦'; position: absolute; right: -0.3em; color: var(--saffron); }
  @keyframes tick { to { transform: translateX(-50%); } }
  .ticker:hover .ticker__track { animation-play-state: paused; }

  .nav {
    position: fixed; top: 33px; left: 0; right: 0; z-index: 200;
    transition: background 0.4s var(--ease), box-shadow 0.4s, border-color 0.4s;
    border-bottom: 2.5px solid transparent;
  }
  .nav.stuck { background: var(--paper-2); border-bottom-color: var(--ink); box-shadow: 0 6px 0 -3px rgba(33,28,23,0.12); }
  .nav__inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-block: 0.7rem; }
  .nav__brand { display: flex; align-items: center; gap: 0.7rem; }
  .nav__seal { width: 46px; height: 46px; line-height: 1; font-size: 0.55rem; background: var(--saffron); flex: none; transform: rotate(-6deg); }
  .nav__word { font-family: var(--display); font-weight: 800; font-size: 1.5rem; text-transform: uppercase; letter-spacing: -0.03em; line-height: 0.85; }
  .nav__word em { display: block; font-size: 0.95rem; color: var(--pomodoro); letter-spacing: 0; }

  .nav__links { display: none; gap: 1.6rem; }
  .nav__links a { position: relative; padding-block: 0.2rem; transition: color 0.3s; }
  .nav__links a:hover { color: var(--pomodoro); }
  .nav__links a::after { content: ''; position: absolute; left: 0; bottom: -2px; width: 0; height: 2px; background: var(--pomodoro); transition: width 0.35s var(--ease); }
  .nav__links a:hover::after { width: 100%; }

  .nav__cta {
    display: inline-flex; align-items: center; gap: 0.5rem; background: var(--pomodoro); color: var(--cream);
    font-family: var(--display); font-weight: 800; text-transform: uppercase; letter-spacing: 0.02em;
    padding: 0.6rem 1.2rem; border: var(--rule); box-shadow: 4px 4px 0 var(--ink);
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .nav__cta:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }
  .nav__cta:active { transform: translate(2px, 2px); box-shadow: 1px 1px 0 var(--ink); }
  .nav__cta-x { transition: transform 0.3s var(--ease); }
  .nav__cta:hover .nav__cta-x { transform: rotate(45deg); }

  @media (min-width: 920px) { .nav__links { display: flex; } }
</style>
