---
const tech = [
  { k: 'A', t: 'Streaming multi-camera', d: 'Inquadratura dall’alto, laterale e ravvicinata: cambiano in diretta, non perdi una piega.' },
  { k: 'B', t: 'Qualsiasi schermo', d: 'Casti sulla TV, appoggi un tablet o guardi dal portatile. Serve solo il Wi-Fi.' },
  { k: 'C', t: 'Audio bidirezionale', d: 'Togli il muto quando vuoi e chiedi alla nonna — è un corso vero, non una replica.' },
  { k: 'D', t: 'Il tuo fuso orario', d: 'Rileviamo la tua ora locale e la mostriamo accanto all’ora di Firenze.' },
];
const box = [
  { name: 'Farina 00 & Semola', note: 'macinata in Toscana, già dosata' },
  { name: 'Matterello', note: 'di legno, tuo per sempre' },
  { name: 'Trafila di bronzo', note: 'per pappardelle rigate' },
  { name: 'Schede ricetta', note: 'a rilievo, a prova di sugo' },
  { name: 'Olio EVO toscano', note: '100ml di oro liquido' },
];
---

<section class="onl" id="online">
  <div class="wrap">
    <div class="onl__head" data-reveal>
      <span class="tag" style="background:var(--saffron)">Corsi in diretta</span>
      <h2 class="onl__title ghost" data-ghost="La cucina">La cucina<br/>arriva <em class="ser">da te.</em></h2>
      <p class="onl__lede">Stessa nonna, stessa pasta, trasmessa in alta definizione da Firenze. Gli ingredienti li spediamo noi.</p>
    </div>

    <div class="onl__split">
      <div class="onl__studio" data-reveal data-hot>
        <div class="studio">
          <span class="studio__live mono"><i></i> in diretta</span>
          <div class="studio__main"><span class="studio__dough"></span></div>
          <div class="studio__cam studio__cam--a mono">CAM · ALTO</div>
          <div class="studio__cam studio__cam--b mono">CAM · MANI</div>
          <div class="studio__bar"><button class="studio__play" aria-label="Anteprima">▶</button><span class="mono">Anteprima 40s</span><span class="mono studio__cams">3 cam</span></div>
        </div>
      </div>

      <div class="onl__info" data-reveal style="--d:120ms">
        <h3 class="onl__h3">Montato come uno studio TV.<br/>Vissuto come una cucina di casa.</h3>
        <ul class="tech">
          {tech.map((x) => (
            <li class="tech__i">
              <span class="tech__k">{x.k}</span>
              <div><p class="tech__t">{x.t}</p><p class="tech__d">{x.d}</p></div>
            </li>
          ))}
        </ul>
        <button class="ebtn ebtn--saff" data-open-booking data-prefill="online" data-hot>Prenota la diretta ↗</button>
      </div>
    </div>

    <div class="box2" data-reveal>
      <div class="box2__head">
        <h3 class="box2__title">Nel cofanetto <em class="ser">spedito a casa.</em></h3>
        <div class="box2__nav"><button data-bp aria-label="Indietro">←</button><button data-bn aria-label="Avanti">→</button></div>
      </div>
      <div class="box2__track" data-track>
        {box.map((b, i) => (
          <article class="kit2" data-hot>
            <span class="kit2__n mono">{String(i + 1).padStart(2, '0')}</span>
            <div class="kit2__sq"></div>
            <p class="kit2__name">{b.name}</p>
            <p class="kit2__note mono">{b.note}</p>
          </article>
        ))}
      </div>
      <p class="box2__foot mono">Spedizione gratis UE & UK · €12 nel mondo · arriva refrigerato 2 giorni prima</p>
    </div>
  </div>
</section>

<script>
  const setBox = () => {
    const tr = document.querySelector<HTMLElement>('[data-track]');
    if (!tr) return;
    const step = () => { const f = tr.querySelector<HTMLElement>('.kit2'); return f ? f.offsetWidth + 18 : 260; };
    document.querySelector('[data-bp]')?.addEventListener('click', () => tr.scrollBy({ left: -step(), behavior: 'smooth' }));
    document.querySelector('[data-bn]')?.addEventListener('click', () => tr.scrollBy({ left: step(), behavior: 'smooth' }));
  };
  setBox();
  document.addEventListener('astro:after-swap', setBox);
</script>

<style>
  .onl { background: var(--ink); color: var(--cream); padding-block: clamp(4rem, 11vh, 8rem); border-bottom: var(--rule); position: relative; }
  .onl::before { content: ''; position: absolute; inset: 0; opacity: 0.06; background-image: radial-gradient(var(--cream) 0.6px, transparent 0.7px); background-size: 7px 7px; }
  .onl__head { max-width: 44ch; margin-bottom: clamp(2.5rem, 6vw, 4rem); }
  .onl__title { font-size: var(--t-3); margin-top: 1rem; }
  .onl__title em { color: var(--saffron); font-weight: 500; }
  .onl__title.ghost::before { color: var(--pomodoro); -webkit-text-fill-color: var(--pomodoro); }
  .onl__lede { font-family: var(--display); font-weight: 400; text-transform: none; letter-spacing: 0; margin-top: 1rem; font-size: var(--t-1); color: rgba(247,240,223,0.78); }

  .onl__split { display: grid; gap: clamp(1.6rem, 4vw, 3rem); grid-template-columns: 1fr; align-items: center; margin-bottom: clamp(3rem, 8vw, 6rem); }
  @media (min-width: 900px) { .onl__split { grid-template-columns: 1.05fr 0.95fr; } }

  .studio { position: relative; aspect-ratio: 4/3; border: 2.5px solid var(--cream); padding: 12px; display: grid; gap: 10px; grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr auto; box-shadow: 8px 8px 0 var(--pomodoro); }
  .studio__main { grid-row: 1/3; background: var(--pomodoro); position: relative; overflow: hidden; }
  .studio__dough { position: absolute; inset: 0; margin: auto; width: 52%; height: 52%; border-radius: 50%; background: radial-gradient(circle at 40% 35%, var(--paper-2), var(--saffron) 75%); box-shadow: inset -6px -8px 14px rgba(168,35,28,0.5); animation: dspin 12s linear infinite; }
  @keyframes dspin { to { transform: rotate(360deg); } }
  .studio__cam { padding: 8px; color: rgba(247,240,223,0.75); display: flex; align-items: flex-start; }
  .studio__cam--a { background: var(--basilico); } .studio__cam--b { background: #6a4a28; }
  .studio__live { position: absolute; top: 18px; left: 18px; z-index: 2; background: var(--ink); padding: 4px 9px; display: inline-flex; align-items: center; gap: 6px; color: var(--cream); }
  .studio__live i { width: 7px; height: 7px; border-radius: 50%; background: var(--pomodoro); animation: lpulse 1.3s infinite; }
  @keyframes lpulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .studio__bar { grid-column: 1/3; display: flex; align-items: center; gap: 12px; color: rgba(247,240,223,0.8); }
  .studio__play { width: 32px; height: 32px; border-radius: 50%; background: var(--saffron); color: var(--ink); font-size: 0.7rem; }
  .studio__cams { margin-left: auto; }

  .onl__h3 { font-size: var(--t-2); margin-bottom: 1.6rem; }
  .tech { display: grid; gap: 1.1rem; margin-bottom: 1.8rem; }
  .tech__i { display: flex; gap: 0.9rem; }
  .tech__k { flex: none; width: 40px; height: 40px; display: grid; place-content: center; border: 2px solid var(--saffron); color: var(--saffron); font-family: var(--serif); font-style: italic; font-size: 1.2rem; }
  .tech__t { font-weight: 800; text-transform: uppercase; letter-spacing: -0.01em; }
  .tech__d { font-family: var(--display); font-weight: 400; text-transform: none; letter-spacing: 0; font-size: var(--t--1); color: rgba(247,240,223,0.65); line-height: 1.45; }
  .ebtn--saff { background: var(--saffron); color: var(--ink); box-shadow: 5px 5px 0 var(--cream); }
  .ebtn--saff:hover { transform: translate(-2px,-2px); box-shadow: 7px 7px 0 var(--cream); }

  .box2 { border-top: 2.5px solid rgba(247,240,223,0.25); padding-top: clamp(2rem, 5vw, 3rem); }
  .box2__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 1.6rem; }
  .box2__title { font-size: var(--t-2); } .box2__title em { color: var(--saffron); font-weight: 500; }
  .box2__nav { display: flex; gap: 0.6rem; }
  .box2__nav button { width: 46px; height: 46px; border: 2px solid var(--cream); border-radius: 50%; color: var(--cream); font-size: 1.1rem; transition: background 0.25s, color 0.25s, transform 0.25s; }
  .box2__nav button:hover { background: var(--saffron); color: var(--ink); border-color: var(--saffron); transform: scale(1.06); }

  .box2__track { display: flex; gap: 18px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; padding-bottom: 0.5rem; margin-inline: calc(var(--gutter) * -1); padding-inline: var(--gutter); }
  .box2__track::-webkit-scrollbar { display: none; }
  .kit2 { flex: 0 0 clamp(180px, 36vw, 230px); scroll-snap-align: start; }
  .kit2__n { color: var(--saffron); }
  .kit2__sq { aspect-ratio: 1; margin: 0.5rem 0 0.8rem; border: 2px solid var(--cream); background: linear-gradient(135deg, var(--pomodoro), var(--pomodoro-deep)); transition: transform 0.4s var(--ease); }
  .kit2:nth-child(2n) .kit2__sq { background: linear-gradient(135deg, var(--saffron), #b87c0e); }
  .kit2:nth-child(3n) .kit2__sq { background: linear-gradient(135deg, var(--basilico), #2a3f27); }
  .kit2:hover .kit2__sq { transform: translate(-4px,-4px); box-shadow: 6px 6px 0 var(--saffron); }
  .kit2__name { font-weight: 800; text-transform: uppercase; font-size: var(--t-0); }
  .kit2__note { color: rgba(247,240,223,0.6); }
  .box2__foot { margin-top: 1.4rem; color: rgba(247,240,223,0.55); }
</style>
