---
import { ClientRouter } from 'astro:transitions';
import '../styles/edizione.css';

interface Props { title?: string; description?: string; }
const {
  title = 'Pasta Firenze — Edizione · Fatta a mano dal 1978',
  description = 'A 1970s print-shop take on Florence pasta classes. Learn to roll fresh pasta in person or live online, kit shipped worldwide.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#d2342b" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23d2342b'/%3E%3Ctext y='25' x='5' font-size='22' font-family='Georgia' fill='%23f7f0df' font-style='italic'%3EP%3C/text%3E%3C/svg%3E" />
    <ClientRouter />
  </head>
  <body>
    <!-- ===== Loader: rotating seal + halftone wipe ===== -->
    <div id="ldr" class="ldr" aria-hidden="true">
      <div class="ldr__stamp">
        <svg viewBox="0 0 200 200" class="ldr__ring">
          <defs><path id="circ" d="M100,100 m-74,0 a74,74 0 1,1 148,0 a74,74 0 1,1 -148,0" /></defs>
          <text class="ldr__circtext"><textPath href="#circ">PASTA · FATTA · A · MANO · FIRENZE · DAL 1978 · </textPath></text>
        </svg>
        <span class="ldr__fork">🍴</span>
      </div>
      <p class="ldr__word mono">Apparecchiando la tavola</p>
    </div>

    <slot />

    <!-- custom cursor -->
    <div class="cursor" id="cur"></div>
    <div class="cursor-ring" id="curr"></div>

    <script>
      // ---- loader ----
      const drop = () => {
        const l = document.getElementById('ldr');
        if (!l) return;
        l.classList.add('done');
        setTimeout(() => l.remove(), 900);
      };
      if (document.readyState === 'complete') setTimeout(drop, 700);
      else window.addEventListener('load', () => setTimeout(drop, 700));

      // ---- custom cursor ----
      const cur = document.getElementById('cur');
      const ring = document.getElementById('curr');
      if (cur && ring && window.matchMedia('(hover: hover)').matches) {
        let rx = 0, ry = 0, x = 0, y = 0;
        window.addEventListener('mousemove', (e) => {
          x = e.clientX; y = e.clientY;
          cur.style.transform = `translate(${x}px, ${y}px) translate(-50%, -50%)`;
        });
        const loop = () => { rx += (x - rx) * 0.18; ry += (y - ry) * 0.18; ring.style.transform = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`; requestAnimationFrame(loop); };
        loop();
        const hot = () => ring.classList.add('hot');
        const cool = () => ring.classList.remove('hot');
        const bind = () => document.querySelectorAll('a, button, [data-hot]').forEach((el) => {
          el.addEventListener('mouseenter', hot); el.addEventListener('mouseleave', cool);
        });
        bind();
        document.addEventListener('astro:after-swap', bind);
      }

      // ---- reveal ----
      const reveal = () => {
        const els = document.querySelectorAll('[data-reveal]');
        if (!('IntersectionObserver' in window)) return els.forEach((e) => e.classList.add('in'));
        const io = new IntersectionObserver((ents) => ents.forEach((en) => {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        }), { rootMargin: '0px 0px -8% 0px', threshold: 0.1 });
        els.forEach((e) => io.observe(e));
      };
      reveal();
      document.addEventListener('astro:after-swap', reveal);

      // ---- parallax ----
      const para = () => {
        const layers = document.querySelectorAll<HTMLElement>('[data-para]');
        if (!layers.length) return;
        let t = false;
        const on = () => {
          if (t) return; t = true;
          requestAnimationFrame(() => {
            const y = window.scrollY;
            layers.forEach((el) => { el.style.transform = `translate3d(0, ${y * parseFloat(el.dataset.para || '0.1')}px, 0)`; });
            t = false;
          });
        };
        window.addEventListener('scroll', on, { passive: true }); on();
      };
      para();
    </script>

    <style is:global>
      /* ===== Loader ===== */
      .ldr {
        position: fixed; inset: 0; z-index: 10000; display: grid; place-content: center; justify-items: center; gap: 1.6rem;
        background: var(--pomodoro);
        transition: clip-path 0.85s var(--ease), opacity 0.5s ease 0.4s;
        clip-path: inset(0 0 0 0);
      }
      .ldr.done { clip-path: inset(0 0 100% 0); opacity: 0; pointer-events: none; }
      .ldr__stamp { position: relative; width: 170px; height: 170px; display: grid; place-content: center; }
      .ldr__ring { position: absolute; inset: 0; width: 170px; height: 170px; animation: ldrspin 9s linear infinite; }
      .ldr__circtext { fill: var(--cream); font-family: var(--mono); font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase; }
      @keyframes ldrspin { to { transform: rotate(360deg); } }
      .ldr__fork { font-size: 2.6rem; animation: forkbob 1.3s var(--ease) infinite; }
      @keyframes forkbob { 0%,100% { transform: translateY(0) rotate(-6deg); } 50% { transform: translateY(-8px) rotate(6deg); } }
      .ldr__word { color: var(--cream); letter-spacing: 0.25em; opacity: 0.9; }

      /* ===== View transitions ===== */
      @keyframes ein { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: none; } }
      ::view-transition-old(root) { animation: 0.25s var(--ease) both fout; }
      ::view-transition-new(root) { animation: 0.4s var(--ease) both ein; }
      @keyframes fout { to { opacity: 0; } }
    </style>
  </body>
</html>
