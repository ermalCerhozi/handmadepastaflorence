---
import { ClientRouter } from 'astro:transitions';
import Schema from '../components/Schema.astro';
import '../styles/global.css';
import { getLocaleFromUrl, getAlternates, type Alternate } from '../i18n/utils';
import { defaultLocale, languages } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Per-page hreflang alternates (landing pages pass translated slugs). */
  alternates?: Alternate[];
}

const {
  title = 'Handmade Pasta Florence — Cooking Classes & Pasta Experiences in the Oltrarno',
  description = 'Hands-on pasta making classes in Florence taught by two Tuscan agriturismo head chefs. Max 8 guests in our Oltrarno kitchen from €95, market-tour and private options, or live online with an ingredient kit from €68.',
  image = '/images/og-share.jpg',
  alternates,
} = Astro.props;

const lang = getLocaleFromUrl(Astro.url);
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

// Hreflang: use the page's explicit alternates (landing pages) or derive them
// generically for same-slug pages (home, blog). x-default points at the default
// locale. Adding a locale in config.ts extends this automatically.
const alts = (alternates ?? getAlternates(Astro.url.pathname)).map((a) => ({
  hreflang: languages[a.locale].htmlLang,
  href: new URL(a.path, Astro.site).href,
  isDefault: a.locale === defaultLocale,
}));
const xDefault = alts.find((a) => a.isDefault) ?? alts[0];

const ogLocale = languages[lang].ogLocale;
const dir = languages[lang].dir;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alts.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Handmade Pasta Florence" />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#2c3a29" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <Schema />
    <ClientRouter />
    <script is:inline define:vars={{ isRoot: Astro.url.pathname === '/' }}>
      if (isRoot) {
        try {
          var pref = localStorage.getItem('preferredLang');
          if (!pref) {
            var browserLang = navigator.language.split('-')[0].toLowerCase();
            var supported = ['it', 'fr', 'de', 'zh'];
            if (supported.indexOf(browserLang) !== -1) {
              window.location.replace('/' + browserLang + '/');
            }
          }
        } catch (e) {}
      }
    </script>
  </head>
  <body>
    <slot />

    <script>
      // ---- Scroll reveal ----
      const setupReveal = () => {
        const els = document.querySelectorAll('[data-reveal]');
        if (!('IntersectionObserver' in window)) {
          els.forEach((e) => e.classList.add('is-in'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add('is-in');
                io.unobserve(en.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.12 }
        );
        els.forEach((e) => io.observe(e));
      };
      setupReveal();
      document.addEventListener('astro:after-swap', setupReveal);

      // ---- Hero parallax (flour-dusted table) ----
      const setupParallax = () => {
        const layers = document.querySelectorAll<HTMLElement>('[data-parallax]');
        if (!layers.length) return;
        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const y = window.scrollY;
            layers.forEach((el) => {
              const speed = parseFloat(el.dataset.parallax || '0.2');
              el.style.transform = `translate3d(0, ${y * speed}px, 0)`;
            });
            ticking = false;
          });
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      };
      setupParallax();
    </script>

    <style is:global>
      /* ============ Astro View Transitions ============ */
      @keyframes pageInUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
      ::view-transition-old(root) { animation: 0.3s var(--ease) both fadeOutPage; }
      ::view-transition-new(root) { animation: 0.45s var(--ease) both pageInUp; }
      @keyframes fadeOutPage { to { opacity: 0; } }
    </style>
  </body>
</html>
