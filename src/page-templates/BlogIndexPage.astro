---
// Shared blog index template
import type { CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingDrawer from '../components/BookingDrawer.astro';
import { getLocaleFromUrl } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const isIt = lang === 'it';

const fmt = (d: Date) =>
  d.toLocaleDateString(isIt ? 'it-IT' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const getLink = (id: string) => {
  return isIt ? `/it/blog/${id.replace('it/', '')}/` : `/blog/${id}/`;
};
---

<Layout
  title={t.meta.blogTitle}
  description={t.meta.blogDescription}
>
  <Header solid />
  <main>
    <section class="bl-hero" id="top">
      <div class="shell">
        <p class="eyebrow bl-hero__eyebrow">{t.blogIndex.eyebrow}</p>
        <h1 class="bl-hero__h">{t.blogIndex.h1}<span class="ital">{t.blogIndex.h1Ital}</span></h1>
        <p class="bl-hero__lede">{t.blogIndex.lede}</p>
      </div>
    </section>

    <section class="bl-list">
      <div class="shell">
        <div class="bl-grid">
          {
            posts.map((p, i) => (
              <a class="bl-card" href={getLink(p.id)} data-reveal style={`--reveal-delay:${i * 60}ms`}>
                <div class="bl-card__media">
                  <img src={p.data.image} alt={p.data.imageAlt} loading="lazy" decoding="async" />
                </div>
                <div class="bl-card__body">
                  <time datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
                  <h2>{p.data.title}</h2>
                  <p>{p.data.description}</p>
                  <span class="bl-card__go">{t.blogIndex.readGuide} <span aria-hidden="true">→</span></span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <BookingDrawer />
</Layout>

<style>
  .bl-hero {
    background: var(--olive-deep);
    color: var(--flour);
    padding-block: clamp(7rem, 16vh, 10rem) clamp(3rem, 7vh, 4.5rem);
  }
  .bl-hero__eyebrow { color: var(--yolk); margin-bottom: 1rem; }
  .bl-hero__h { font-size: var(--step-3); }
  .bl-hero__h .ital { color: var(--yolk); }
  .bl-hero__lede {
    margin-top: 1.1rem; color: rgba(249, 246, 240, 0.8);
    font-size: var(--step-0); line-height: 1.65; max-width: 52ch;
  }

  .bl-list { padding-block: clamp(3rem, 8vh, 5.5rem); }
  .bl-grid {
    display: grid; gap: clamp(1.2rem, 2.5vw, 2rem);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
  }
  .bl-card {
    display: flex; flex-direction: column; background: #fff;
    border: 1px solid var(--paper-line); border-radius: var(--radius-lg);
    overflow: hidden; box-shadow: var(--shadow-sm);
    transition: box-shadow 0.4s var(--ease), transform 0.4s var(--ease);
  }
  .bl-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
  .bl-card__media { aspect-ratio: 16 / 10; overflow: hidden; background: var(--flour-shadow); }
  .bl-card__media img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.7s var(--ease);
  }
  .bl-card:hover .bl-card__media img { transform: scale(1.05); }
  .bl-card__body { padding: 1.4rem 1.5rem 1.6rem; display: flex; flex-direction: column; flex: 1; }
  .bl-card__body time {
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--terracotta);
  }
  .bl-card__body h2 { margin-top: 0.5rem; font-size: var(--step-1); color: var(--olive); }
  .bl-card__body p {
    margin-top: 0.6rem; color: var(--charcoal-soft);
    font-size: var(--step--1); line-height: 1.6; flex: 1;
  }
  .bl-card__go {
    margin-top: 1.1rem; font-weight: 700; font-size: var(--step--1); color: var(--olive);
    border-bottom: 2px solid var(--yolk); align-self: flex-start; padding-bottom: 2px;
  }
</style>
