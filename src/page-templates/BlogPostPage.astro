---
import { render, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingDrawer from '../components/BookingDrawer.astro';
import { getLocaleFromUrl } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
const isIt = lang === 'it';

const SITE = 'https://handmadepastaflorence.com';
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const fmt = (d: Date) =>
  d.toLocaleDateString(isIt ? 'it-IT' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const publisherId = isIt ? `${SITE}/it/#business` : `${SITE}/#business`;
const homeUrl = isIt ? '/it/' : '/';
const blogUrl = isIt ? '/it/blog/' : '/blog/';
const homeItem = isIt ? `${SITE}/it/` : `${SITE}/`;
const blogItem = isIt ? `${SITE}/it/blog/` : `${SITE}/blog/`;
const classesUrl = isIt ? '/it/corso-pasta-fresca-firenze/' : '/pasta-making-class-florence/';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  image: `${SITE}${post.data.image}`,
  datePublished: post.data.pubDate.toISOString(),
  inLanguage: isIt ? 'it' : 'en',
  author: {
    '@type': 'Person',
    name: post.data.author,
    jobTitle: 'Head Chef',
    sameAs: 'https://endricerhozi.com',
  },
  publisher: { '@id': publisherId },
  mainEntityOfPage: canonical,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.blogPost.homeCrumb, item: homeItem },
    { '@type': 'ListItem', position: 2, name: t.blogPost.guidesCrumb, item: blogItem },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
  ],
};

const faqs = post.data.faqs ?? [];
const faqSchema = faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---

<Layout title={`${post.data.title} | Handmade Pasta Florence`} description={post.data.description} image={post.data.image}>
  <Header solid />
  <main>
    <article>
      <header class="po-hero" id="top">
        <div class="shell">
          <nav class="po-crumb" aria-label="Breadcrumb">
            <a href={homeUrl}>{t.blogPost.homeCrumb}</a> <span aria-hidden="true">/</span>
            <a href={blogUrl}>{t.blogPost.guidesCrumb}</a>
          </nav>
          <h1 class="po-hero__h">{post.data.title}</h1>
          <p class="po-hero__meta">
            {t.blogPost.by} <a href="https://endricerhozi.com" target="_blank" rel="noopener">{post.data.author}</a>
            · <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          </p>
        </div>
      </header>

      <div class="shell">
        <figure class="po-figure">
          <img src={post.data.image} alt={post.data.imageAlt} decoding="async" />
        </figure>

        <div class="po-body">
          <Content />
        </div>

        {faqs.length > 0 && (
          <section class="po-faq" aria-label={t.blogPost.faqTitle}>
            <h2 class="po-faq__h">{t.blogPost.faqTitle}</h2>
            <div class="po-faq__list">
              {faqs.map((f) => (
                <details class="po-faq__item">
                  <summary class="po-faq__q">{f.q}<span class="po-faq__icon" aria-hidden="true">+</span></summary>
                  <p class="po-faq__a">{f.a}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        <aside class="po-bio" data-reveal>
          <p>
            <strong>{post.data.author}</strong> {t.blogPost.bioIs}
            <a href={classesUrl}>{t.blogPost.bioLink}</a> {t.blogPost.bioEnd}
          </p>
        </aside>

        <div class="po-cta" data-reveal>
          <div>
            <h2>{t.blogPost.ctaH2}</h2>
            <p>{t.blogPost.ctaP}</p>
          </div>
          <div class="po-cta__actions">
            <button class="po-cta__btn" data-open-booking>{t.blogPost.ctaBtn}</button>
            <a class="po-cta__link" href={classesUrl}>{t.blogPost.ctaLink}</a>
          </div>
        </div>
      </div>

      <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
      {faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    </article>
  </main>
  <Footer />
  <BookingDrawer />
</Layout>

<style>
  .po-hero {
    background: var(--olive-deep); color: var(--flour);
    padding-block: clamp(7rem, 16vh, 10rem) clamp(2.5rem, 6vh, 4rem);
  }
  .po-crumb { font-size: var(--step--1); color: rgba(249, 246, 240, 0.55); margin-bottom: 1.3rem; }
  .po-crumb a {
    color: rgba(249, 246, 240, 0.75); text-decoration: underline;
    text-underline-offset: 3px; transition: color 0.3s;
  }
  .po-crumb a:hover { color: var(--flour); }
  .po-crumb span[aria-hidden] { margin-inline: 0.4rem; }
  .po-hero__h { font-size: var(--step-3); line-height: 1.1; max-width: 24ch; }
  .po-hero__meta { margin-top: 1.1rem; font-size: var(--step--1); color: rgba(249, 246, 240, 0.7); }
  .po-hero__meta a {
    color: rgba(249, 246, 240, 0.9); text-decoration: underline; text-underline-offset: 3px;
  }

  .po-figure {
    max-width: 820px; margin-top: clamp(-2rem, -4vh, -3rem);
    border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-lg);
    aspect-ratio: 16 / 9; background: var(--flour-shadow); position: relative;
  }
  .po-figure img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .po-body { max-width: 720px; padding-block: clamp(2.5rem, 6vh, 4rem) 1rem; }
  .po-body :global(h2) {
    font-size: var(--step-2); color: var(--olive);
    margin: 2.2rem 0 0.8rem;
  }
  .po-body :global(h3) { font-size: var(--step-1); color: var(--olive); margin: 1.8rem 0 0.6rem; }
  .po-body :global(p) { color: var(--charcoal); line-height: 1.75; font-size: var(--step-0); margin-bottom: 1rem; }
  .po-body :global(ul),
  .po-body :global(ol) { margin: 0 0 1.2rem; padding-left: 1.2rem; display: grid; gap: 0.5rem; }
  .po-body :global(li) { color: var(--charcoal); line-height: 1.65; font-size: var(--step-0); }
  .po-body :global(li::marker) { color: var(--terracotta); font-weight: 800; }
  .po-body :global(a) { color: var(--terracotta); text-decoration: underline; text-underline-offset: 3px; }
  .po-body :global(strong) { color: var(--olive); }
  .po-body :global(blockquote) {
    border-left: 3px solid var(--yolk); padding-left: 1.1rem; margin: 1.4rem 0;
    font-style: italic; color: var(--charcoal-soft);
  }

  .po-faq { max-width: 720px; margin-top: 2.5rem; }
  .po-faq__h { font-size: var(--step-2); color: var(--olive); margin-bottom: 1.2rem; }
  .po-faq__list { display: grid; gap: 0.8rem; }
  .po-faq__item {
    background: var(--flour); border: 1px solid var(--paper-line);
    border-radius: var(--radius); padding: 0 1.3rem; box-shadow: var(--shadow-sm);
  }
  .po-faq__q {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    cursor: pointer; list-style: none; padding: 1.1rem 0;
    font-family: var(--serif); font-weight: 700; font-size: var(--step-0); color: var(--olive);
  }
  .po-faq__q::-webkit-details-marker { display: none; }
  .po-faq__icon { color: var(--terracotta); font-size: 1.4rem; line-height: 1; flex-shrink: 0; transition: transform 0.3s var(--ease); }
  .po-faq__item[open] .po-faq__icon { transform: rotate(45deg); }
  .po-faq__a { margin: 0 0 1.2rem; color: var(--charcoal); line-height: 1.65; font-size: var(--step--1); }

  .po-bio {
    max-width: 720px; margin-top: 1.5rem; padding: 1.2rem 1.4rem;
    background: var(--flour); border: 1px solid var(--paper-line); border-radius: var(--radius);
  }
  .po-bio p { font-size: var(--step--1); line-height: 1.6; color: var(--charcoal); }
  .po-bio a { color: var(--terracotta); text-decoration: underline; text-underline-offset: 3px; }

  .po-cta {
    max-width: 720px; margin-block: 2rem clamp(3rem, 8vh, 5rem);
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 1.2rem; padding: clamp(1.5rem, 3vw, 2.2rem);
    background: var(--olive); color: var(--flour); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .po-cta h2 { font-size: var(--step-1); }
  .po-cta p { margin-top: 0.4rem; font-size: var(--step--1); color: rgba(249, 246, 240, 0.8); }
  .po-cta__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem 1.4rem; }
  .po-cta__btn {
    background: var(--yolk); color: var(--olive-deep); font-weight: 800;
    padding: 0.85rem 1.5rem; border-radius: 100px; transition: transform 0.3s var(--ease);
  }
  .po-cta__btn:hover { transform: translateY(-2px); }
  .po-cta__link {
    font-weight: 600; font-size: var(--step--1); color: rgba(249, 246, 240, 0.85);
    text-decoration: underline; text-underline-offset: 3px;
  }
  .po-cta__link:hover { color: var(--yolk); }
</style>
