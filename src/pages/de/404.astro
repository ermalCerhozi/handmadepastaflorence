---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Pagina non trovata — Handmade Pasta Florence"
  description="Questa pagina si è allontanata dal tavolo. Torna in cucina."
>
  <main class="nf">
    <p class="nf__emoji" aria-hidden="true">🍝</p>
    <h1 class="nf__title">Perso nella farina</h1>
    <p class="nf__text">Questa pagina si è allontanata dal tavolo. Ti riportiamo in cucina.</p>
    <a href="/it/" class="btn btn--solid nf__btn">Torna alla home</a>
  </main>
</Layout>

<style>
  .nf {
    min-height: 72vh; display: grid; place-content: center; justify-items: center;
    gap: 1.1rem; text-align: center; padding: 4rem 1.5rem;
  }
  .nf__emoji { font-size: 3.5rem; margin: 0; }
  .nf__title { font-family: var(--serif); font-size: var(--step-3); color: var(--olive); margin: 0; }
  .nf__text { color: var(--charcoal-soft); max-width: 42ch; margin: 0; }
  .nf__btn { margin-top: 0.6rem; }
</style>
