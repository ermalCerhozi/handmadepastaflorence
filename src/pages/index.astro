---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import WhyUs from '../components/WhyUs.astro';
import Experiences from '../components/Experiences.astro';
import Reviews from '../components/Reviews.astro';
import PastaGallery from '../components/PastaGallery.astro';
import Story from '../components/Story.astro';
import OnlineBand from '../components/OnlineBand.astro';
import Faq from '../components/Faq.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import BookingDrawer from '../components/BookingDrawer.astro';
---

